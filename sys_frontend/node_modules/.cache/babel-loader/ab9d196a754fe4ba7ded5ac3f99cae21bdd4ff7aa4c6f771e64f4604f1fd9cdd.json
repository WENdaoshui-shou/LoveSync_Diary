{"ast":null,"code":"import { getUserInfo } from '@/api/auth';\nexport default {\n  name: 'AdminLayout',\n  data() {\n    return {\n      userInfo: null\n    };\n  },\n  created() {\n    this.loadUserInfo();\n  },\n  methods: {\n    async loadUserInfo() {\n      try {\n        const response = await getUserInfo();\n        console.log('用户信息响应:', response);\n\n        // 检查响应格式，适配不同的API响应格式\n        if (response.data) {\n          if (response.data.success === true && response.data.data) {\n            // 标准格式: { success: true, data: {...} }\n            console.log('用户信息获取成功（标准格式）');\n            this.userInfo = response.data.data;\n          } else if (response.data.code === 200 && response.data.data) {\n            // 另一种格式: { code: 200, data: {...} }\n            console.log('用户信息获取成功（code格式）');\n            this.userInfo = response.data.data;\n          } else if (response.data.id) {\n            // 直接返回用户数据\n            console.log('用户信息获取成功（直接数据）');\n            this.userInfo = response.data;\n          } else {\n            console.error('获取用户信息失败，未知响应格式:', response.data);\n          }\n        } else {\n          console.error('获取用户信息失败，响应为空');\n        }\n      } catch (error) {\n        console.error('获取用户信息失败:', error);\n        // 如果是401错误，让路由守卫处理\n        if (error.response && error.response.status === 401) {\n          console.log('用户未认证，需要重新登录');\n          // 不要在这里清除token或跳转，让路由守卫处理\n        }\n      }\n    },\n    handleCommand(command) {\n      if (command === 'logout') {\n        this.logout();\n      }\n    },\n    logout() {\n      this.$confirm('确定要退出登录吗？', '确认退出', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        localStorage.removeItem('admin_token');\n        this.$router.replace('/login');\n        this.$message.success('退出登录成功');\n      }).catch(() => {\n        // 用户取消\n      });\n    }\n  }\n};","map":{"version":3,"names":["getUserInfo","name","data","userInfo","created","loadUserInfo","methods","response","console","log","success","code","id","error","status","handleCommand","command","logout","$confirm","confirmButtonText","cancelButtonText","type","then","localStorage","removeItem","$router","replace","$message","catch"],"sources":["src/views/Layout.vue"],"sourcesContent":["<template>\n  <el-container class=\"layout-container\">\n    <!-- 头部 -->\n    <el-header class=\"layout-header\">\n      <div class=\"header-content\">\n        <div class=\"logo\">\n          <h2>LoveSync 管理后台</h2>\n        </div>\n        <div class=\"header-right\">\n          <el-dropdown @command=\"handleCommand\">\n            <span class=\"el-dropdown-link\">\n              <i class=\"el-icon-user\"></i>\n              {{ userInfo?.name || '管理员' }}\n              <i class=\"el-icon-arrow-down el-icon--right\"></i>\n            </span>\n            <el-dropdown-menu slot=\"dropdown\">\n              <el-dropdown-item command=\"logout\">退出登录</el-dropdown-item>\n            </el-dropdown-menu>\n          </el-dropdown>\n        </div>\n      </div>\n    </el-header>\n\n    <el-container>\n      <!-- 侧边栏 -->\n      <el-aside width=\"200px\" class=\"layout-aside\">\n        <el-menu :default-active=\"$route.path\" class=\"layout-menu\" router background-color=\"#304156\"\n          text-color=\"#bfcbd9\" active-text-color=\"#409EFF\">\n          <el-menu-item index=\"/\">\n            <i class=\"el-icon-s-home\"></i>\n            <span slot=\"title\">首页</span>\n          </el-menu-item>\n\n          <el-menu-item index=\"/users\">\n            <i class=\"el-icon-user\"></i>\n            <span slot=\"title\">用户管理</span>\n          </el-menu-item>\n\n          <el-menu-item index=\"/moments\">\n            <i class=\"el-icon-document\"></i>\n            <span slot=\"title\">动态管理</span>\n          </el-menu-item>\n\n          <el-submenu index=\"/community\">\n            <template slot=\"title\">\n              <i class=\"el-icon-chat-dot-round\"></i>\n              <span>社区管理</span>\n            </template>\n            <el-menu-item index=\"/community/events\">\n              <i class=\"el-icon-calendar\"></i>\n              <span slot=\"title\">社区活动</span>\n            </el-menu-item>\n            <el-menu-item index=\"/community/achievements\">\n              <i class=\"el-icon-trophy\"></i>\n              <span slot=\"title\">成就系统</span>\n            </el-menu-item>\n            <el-menu-item index=\"/community/topics\">\n              <i class=\"el-icon-chat-line-round\"></i>\n              <span slot=\"title\">热门话题</span>\n            </el-menu-item>\n            <el-menu-item index=\"/community/reports\">\n              <i class=\"el-icon-warning\"></i>\n              <span slot=\"title\">举报管理</span>\n            </el-menu-item>\n          </el-submenu>\n        </el-menu>\n      </el-aside>\n\n      <!-- 主内容区 -->\n      <el-main class=\"layout-main\">\n        <router-view />\n      </el-main>\n    </el-container>\n  </el-container>\n</template>\n\n<script>\nimport { getUserInfo } from '@/api/auth'\n\nexport default {\n  name: 'AdminLayout',\n  data() {\n    return {\n      userInfo: null\n    }\n  },\n  created() {\n    this.loadUserInfo()\n  },\n  methods: {\n    async loadUserInfo() {\n      try {\n        const response = await getUserInfo()\n        console.log('用户信息响应:', response)\n\n        // 检查响应格式，适配不同的API响应格式\n        if (response.data) {\n          if (response.data.success === true && response.data.data) {\n            // 标准格式: { success: true, data: {...} }\n            console.log('用户信息获取成功（标准格式）')\n            this.userInfo = response.data.data\n          } else if (response.data.code === 200 && response.data.data) {\n            // 另一种格式: { code: 200, data: {...} }\n            console.log('用户信息获取成功（code格式）')\n            this.userInfo = response.data.data\n          } else if (response.data.id) {\n            // 直接返回用户数据\n            console.log('用户信息获取成功（直接数据）')\n            this.userInfo = response.data\n          } else {\n            console.error('获取用户信息失败，未知响应格式:', response.data)\n          }\n        } else {\n          console.error('获取用户信息失败，响应为空')\n        }\n      } catch (error) {\n        console.error('获取用户信息失败:', error)\n        // 如果是401错误，让路由守卫处理\n        if (error.response && error.response.status === 401) {\n          console.log('用户未认证，需要重新登录')\n          // 不要在这里清除token或跳转，让路由守卫处理\n        }\n      }\n    },\n\n    handleCommand(command) {\n      if (command === 'logout') {\n        this.logout()\n      }\n    },\n\n    logout() {\n      this.$confirm('确定要退出登录吗？', '确认退出', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        localStorage.removeItem('admin_token')\n        this.$router.replace('/login')\n        this.$message.success('退出登录成功')\n      }).catch(() => {\n        // 用户取消\n      })\n    }\n  }\n}\n</script>\n\n<style scoped>\n.layout-container {\n  height: 100vh;\n}\n\n.layout-header {\n  background-color: #fff;\n  box-shadow: 0 2px 4px rgba(0, 21, 41, 0.08);\n  padding: 0 20px;\n}\n\n.header-content {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  height: 60px;\n}\n\n.logo h2 {\n  margin: 0;\n  color: #303133;\n  font-size: 20px;\n}\n\n.header-right {\n  display: flex;\n  align-items: center;\n}\n\n.el-dropdown-link {\n  cursor: pointer;\n  color: #409EFF;\n}\n\n.layout-aside {\n  background-color: #304156;\n  border-right: 1px solid #e6e6e6;\n}\n\n.layout-menu {\n  border-right: none;\n  height: calc(100vh - 60px);\n}\n\n.layout-main {\n  background-color: #f5f5f5;\n  padding: 20px;\n}\n</style>"],"mappings":"AA6EA,SAAAA,WAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,QAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,YAAA;EACA;EACAC,OAAA;IACA,MAAAD,aAAA;MACA;QACA,MAAAE,QAAA,SAAAP,WAAA;QACAQ,OAAA,CAAAC,GAAA,YAAAF,QAAA;;QAEA;QACA,IAAAA,QAAA,CAAAL,IAAA;UACA,IAAAK,QAAA,CAAAL,IAAA,CAAAQ,OAAA,aAAAH,QAAA,CAAAL,IAAA,CAAAA,IAAA;YACA;YACAM,OAAA,CAAAC,GAAA;YACA,KAAAN,QAAA,GAAAI,QAAA,CAAAL,IAAA,CAAAA,IAAA;UACA,WAAAK,QAAA,CAAAL,IAAA,CAAAS,IAAA,YAAAJ,QAAA,CAAAL,IAAA,CAAAA,IAAA;YACA;YACAM,OAAA,CAAAC,GAAA;YACA,KAAAN,QAAA,GAAAI,QAAA,CAAAL,IAAA,CAAAA,IAAA;UACA,WAAAK,QAAA,CAAAL,IAAA,CAAAU,EAAA;YACA;YACAJ,OAAA,CAAAC,GAAA;YACA,KAAAN,QAAA,GAAAI,QAAA,CAAAL,IAAA;UACA;YACAM,OAAA,CAAAK,KAAA,qBAAAN,QAAA,CAAAL,IAAA;UACA;QACA;UACAM,OAAA,CAAAK,KAAA;QACA;MACA,SAAAA,KAAA;QACAL,OAAA,CAAAK,KAAA,cAAAA,KAAA;QACA;QACA,IAAAA,KAAA,CAAAN,QAAA,IAAAM,KAAA,CAAAN,QAAA,CAAAO,MAAA;UACAN,OAAA,CAAAC,GAAA;UACA;QACA;MACA;IACA;IAEAM,cAAAC,OAAA;MACA,IAAAA,OAAA;QACA,KAAAC,MAAA;MACA;IACA;IAEAA,OAAA;MACA,KAAAC,QAAA;QACAC,iBAAA;QACAC,gBAAA;QACAC,IAAA;MACA,GAAAC,IAAA;QACAC,YAAA,CAAAC,UAAA;QACA,KAAAC,OAAA,CAAAC,OAAA;QACA,KAAAC,QAAA,CAAAjB,OAAA;MACA,GAAAkB,KAAA;QACA;MAAA,CACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}