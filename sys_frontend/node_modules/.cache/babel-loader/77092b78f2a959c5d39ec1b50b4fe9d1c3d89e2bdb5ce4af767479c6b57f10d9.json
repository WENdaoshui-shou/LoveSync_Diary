{"ast":null,"code":"export default {\n  name: 'TestManagement',\n  data() {\n    return {\n      loading: false,\n      tests: [],\n      total: 0,\n      currentPage: 1,\n      pageSize: 10,\n      filterForm: {\n        search: '',\n        category: ''\n      },\n      dialogVisible: false,\n      dialogTitle: '',\n      form: {\n        id: '',\n        title: '',\n        category: '',\n        question_count: 10,\n        difficulty: '中等',\n        description: '',\n        cover_image: ''\n      },\n      fileList: []\n    };\n  },\n  created() {\n    this.loadData();\n  },\n  methods: {\n    async loadData() {\n      this.loading = true;\n      try {\n        // 这里应该调用API获取数据\n        // const response = await getTests({ page: this.currentPage, page_size: this.pageSize, search: this.filterForm.search, category: this.filterForm.category })\n        // 模拟数据\n        this.tests = [{\n          id: 1,\n          title: '情侣默契大考验',\n          category: '默契测试',\n          question_count: 20,\n          difficulty: '中等',\n          created_at: '2025-02-14',\n          description: '测试情侣之间的默契程度'\n        }, {\n          id: 2,\n          title: '爱情观测试',\n          category: '爱情观测试',\n          question_count: 15,\n          difficulty: '简单',\n          created_at: '2025-02-15',\n          description: '了解彼此的爱情观'\n        }];\n        this.total = this.tests.length;\n      } catch (error) {\n        this.$message.error('加载失败');\n      } finally {\n        this.loading = false;\n      }\n    },\n    handleSearch() {\n      this.currentPage = 1;\n      this.loadData();\n    },\n    resetFilter() {\n      this.filterForm = {\n        search: '',\n        category: ''\n      };\n      this.currentPage = 1;\n      this.loadData();\n    },\n    handleSizeChange(val) {\n      this.pageSize = val;\n      this.loadData();\n    },\n    handleCurrentChange(val) {\n      this.currentPage = val;\n      this.loadData();\n    },\n    addTest() {\n      this.dialogTitle = '添加测试';\n      this.form = {\n        id: '',\n        title: '',\n        category: '',\n        question_count: 10,\n        difficulty: '中等',\n        description: '',\n        cover_image: ''\n      };\n      this.fileList = [];\n      this.dialogVisible = true;\n    },\n    editTest(test) {\n      this.dialogTitle = '编辑测试';\n      this.form = {\n        ...test\n      };\n      this.fileList = [];\n      this.dialogVisible = true;\n    },\n    viewTest(test) {\n      // 查看详情\n      this.$message.info('查看详情功能开发中');\n    },\n    async saveTest() {\n      try {\n        // 这里应该调用API保存数据\n        this.$message.success('保存成功');\n        this.dialogVisible = false;\n        this.loadData();\n      } catch (error) {\n        this.$message.error('保存失败');\n      }\n    },\n    async deleteTest(test) {\n      this.$confirm('确定要删除这个测试吗？', '确认删除', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(async () => {\n        try {\n          // 这里应该调用API删除数据\n          this.$message.success('删除成功');\n          this.loadData();\n        } catch (error) {\n          this.$message.error('删除失败');\n        }\n      }).catch(() => {});\n    },\n    handlePreview(file) {\n      console.log('预览文件:', file);\n    },\n    handleRemove(file, fileList) {\n      console.log('删除文件:', file, fileList);\n    },\n    getDifficultyType(difficulty) {\n      const types = {\n        '简单': 'success',\n        '中等': 'warning',\n        '困难': 'danger'\n      };\n      return types[difficulty] || 'info';\n    }\n  }\n};","map":{"version":3,"names":["name","data","loading","tests","total","currentPage","pageSize","filterForm","search","category","dialogVisible","dialogTitle","form","id","title","question_count","difficulty","description","cover_image","fileList","created","loadData","methods","created_at","length","error","$message","handleSearch","resetFilter","handleSizeChange","val","handleCurrentChange","addTest","editTest","test","viewTest","info","saveTest","success","deleteTest","$confirm","confirmButtonText","cancelButtonText","type","then","catch","handlePreview","file","console","log","handleRemove","getDifficultyType","types"],"sources":["src/views/couple/TestManagement.vue"],"sourcesContent":["<template>\n  <div class=\"test-management\">\n    <div class=\"page-header\">\n      <h1>爱情测试管理</h1>\n      <el-button type=\"primary\" @click=\"addTest\">\n        <i class=\"el-icon-plus\"></i> 添加测试\n      </el-button>\n    </div>\n\n    <el-card class=\"filter-card\">\n      <el-form :inline=\"true\" :model=\"filterForm\" class=\"filter-form\">\n        <el-form-item label=\"搜索\">\n          <el-input v-model=\"filterForm.search\" placeholder=\"搜索测试标题\" clearable @clear=\"handleSearch\" @keyup.enter=\"handleSearch\" style=\"width: 200px\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"分类\">\n          <el-select v-model=\"filterForm.category\" placeholder=\"选择分类\" clearable>\n            <el-option label=\"全部\" value=\"\"></el-option>\n            <el-option label=\"情侣默契\" value=\"默契测试\"></el-option>\n            <el-option label=\"爱情观\" value=\"爱情观测试\"></el-option>\n            <el-option label=\"性格匹配\" value=\"性格测试\"></el-option>\n            <el-option label=\"其他\" value=\"其他测试\"></el-option>\n          </el-select>\n        </el-form-item>\n        <el-form-item>\n          <el-button type=\"primary\" @click=\"handleSearch\">搜索</el-button>\n          <el-button @click=\"resetFilter\">重置</el-button>\n        </el-form-item>\n      </el-form>\n    </el-card>\n\n    <el-card class=\"list-card\">\n      <div slot=\"header\" class=\"card-header\">\n        <span>测试列表</span>\n      </div>\n\n      <el-table :data=\"tests\" v-loading=\"loading\" border style=\"width: 100%\">\n        <el-table-column prop=\"id\" label=\"ID\" width=\"80\" align=\"center\"></el-table-column>\n        <el-table-column prop=\"question\" label=\"测试问题\" min-width=\"200\"></el-table-column>\n        <el-table-column prop=\"user_name\" label=\"创建用户\" width=\"120\"></el-table-column>\n        <el-table-column prop=\"created_at\" label=\"创建时间\" width=\"150\" align=\"center\"></el-table-column>\n        <el-table-column label=\"操作\" width=\"150\" align=\"center\">\n          <template slot-scope=\"scope\">\n            <el-button type=\"text\" size=\"mini\" @click=\"viewTest(scope.row)\">详情</el-button>\n            <el-button type=\"text\" size=\"mini\" @click=\"editTest(scope.row)\">编辑</el-button>\n            <el-button type=\"text\" size=\"mini\" @click=\"deleteTest(scope.row)\" style=\"color: #F56C6C\">删除</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n\n      <div class=\"pagination-container\">\n        <el-pagination @size-change=\"handleSizeChange\" @current-change=\"handleCurrentChange\" :current-page=\"currentPage\" :page-sizes=\"[10, 20, 50, 100]\" :page-size=\"pageSize\" layout=\"total, sizes, prev, pager, next, jumper\" :total=\"total\"></el-pagination>\n      </div>\n    </el-card>\n\n    <!-- 添加/编辑对话框 -->\n    <el-dialog :title=\"dialogTitle\" :visible.sync=\"dialogVisible\" width=\"600px\">\n      <el-form :model=\"form\" label-width=\"100px\">\n        <el-form-item label=\"测试标题\" required>\n          <el-input v-model=\"form.title\" placeholder=\"请输入测试标题\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"分类\">\n          <el-select v-model=\"form.category\" placeholder=\"选择分类\">\n            <el-option label=\"情侣默契\" value=\"默契测试\"></el-option>\n            <el-option label=\"爱情观\" value=\"爱情观测试\"></el-option>\n            <el-option label=\"性格匹配\" value=\"性格测试\"></el-option>\n            <el-option label=\"其他\" value=\"其他测试\"></el-option>\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"题目数量\">\n          <el-input-number v-model=\"form.question_count\" :min=\"1\" :max=\"100\" label=\"数量\"></el-input-number>\n        </el-form-item>\n        <el-form-item label=\"难度\">\n          <el-select v-model=\"form.difficulty\" placeholder=\"选择难度\">\n            <el-option label=\"简单\" value=\"简单\"></el-option>\n            <el-option label=\"中等\" value=\"中等\"></el-option>\n            <el-option label=\"困难\" value=\"困难\"></el-option>\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"描述\">\n          <el-input type=\"textarea\" v-model=\"form.description\" placeholder=\"请输入测试描述\" :rows=\"3\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"封面图片\">\n          <el-upload class=\"upload-demo\" action=\"#\" :on-preview=\"handlePreview\" :on-remove=\"handleRemove\" :file-list=\"fileList\" :auto-upload=\"false\">\n            <el-button size=\"small\" type=\"primary\">点击上传</el-button>\n            <div slot=\"tip\" class=\"el-upload__tip\">只能上传jpg/png文件，且不超过500kb</div>\n          </el-upload>\n        </el-form-item>\n      </el-form>\n      <div slot=\"footer\" class=\"dialog-footer\">\n        <el-button @click=\"dialogVisible = false\">取消</el-button>\n        <el-button type=\"primary\" @click=\"saveTest\">保存</el-button>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'TestManagement',\n  data() {\n    return {\n      loading: false,\n      tests: [],\n      total: 0,\n      currentPage: 1,\n      pageSize: 10,\n      filterForm: {\n        search: '',\n        category: ''\n      },\n      dialogVisible: false,\n      dialogTitle: '',\n      form: {\n        id: '',\n        title: '',\n        category: '',\n        question_count: 10,\n        difficulty: '中等',\n        description: '',\n        cover_image: ''\n      },\n      fileList: []\n    }\n  },\n  created() {\n    this.loadData()\n  },\n  methods: {\n    async loadData() {\n      this.loading = true\n      try {\n        // 这里应该调用API获取数据\n        // const response = await getTests({ page: this.currentPage, page_size: this.pageSize, search: this.filterForm.search, category: this.filterForm.category })\n        // 模拟数据\n        this.tests = [\n          {\n            id: 1,\n            title: '情侣默契大考验',\n            category: '默契测试',\n            question_count: 20,\n            difficulty: '中等',\n            created_at: '2025-02-14',\n            description: '测试情侣之间的默契程度'\n          },\n          {\n            id: 2,\n            title: '爱情观测试',\n            category: '爱情观测试',\n            question_count: 15,\n            difficulty: '简单',\n            created_at: '2025-02-15',\n            description: '了解彼此的爱情观'\n          }\n        ]\n        this.total = this.tests.length\n      } catch (error) {\n        this.$message.error('加载失败')\n      } finally {\n        this.loading = false\n      }\n    },\n    handleSearch() {\n      this.currentPage = 1\n      this.loadData()\n    },\n    resetFilter() {\n      this.filterForm = {\n        search: '',\n        category: ''\n      }\n      this.currentPage = 1\n      this.loadData()\n    },\n    handleSizeChange(val) {\n      this.pageSize = val\n      this.loadData()\n    },\n    handleCurrentChange(val) {\n      this.currentPage = val\n      this.loadData()\n    },\n    addTest() {\n      this.dialogTitle = '添加测试'\n      this.form = {\n        id: '',\n        title: '',\n        category: '',\n        question_count: 10,\n        difficulty: '中等',\n        description: '',\n        cover_image: ''\n      }\n      this.fileList = []\n      this.dialogVisible = true\n    },\n    editTest(test) {\n      this.dialogTitle = '编辑测试'\n      this.form = { ...test }\n      this.fileList = []\n      this.dialogVisible = true\n    },\n    viewTest(test) {\n      // 查看详情\n      this.$message.info('查看详情功能开发中')\n    },\n    async saveTest() {\n      try {\n        // 这里应该调用API保存数据\n        this.$message.success('保存成功')\n        this.dialogVisible = false\n        this.loadData()\n      } catch (error) {\n        this.$message.error('保存失败')\n      }\n    },\n    async deleteTest(test) {\n      this.$confirm('确定要删除这个测试吗？', '确认删除', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(async () => {\n        try {\n          // 这里应该调用API删除数据\n          this.$message.success('删除成功')\n          this.loadData()\n        } catch (error) {\n          this.$message.error('删除失败')\n        }\n      }).catch(() => {})\n    },\n    handlePreview(file) {\n      console.log('预览文件:', file)\n    },\n    handleRemove(file, fileList) {\n      console.log('删除文件:', file, fileList)\n    },\n    getDifficultyType(difficulty) {\n      const types = {\n        '简单': 'success',\n        '中等': 'warning',\n        '困难': 'danger'\n      }\n      return types[difficulty] || 'info'\n    }\n  }\n}\n</script>\n\n<style scoped>\n.test-management {\n  padding: 20px;\n}\n\n.page-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 20px;\n}\n\n.page-header h1 {\n  margin: 0;\n  color: #303133;\n}\n\n.filter-card {\n  margin-bottom: 20px;\n}\n\n.list-card {\n  margin-bottom: 20px;\n}\n\n.card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.pagination-container {\n  margin-top: 20px;\n  text-align: right;\n}\n</style>"],"mappings":"AAiGA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,OAAA;MACAC,KAAA;MACAC,KAAA;MACAC,WAAA;MACAC,QAAA;MACAC,UAAA;QACAC,MAAA;QACAC,QAAA;MACA;MACAC,aAAA;MACAC,WAAA;MACAC,IAAA;QACAC,EAAA;QACAC,KAAA;QACAL,QAAA;QACAM,cAAA;QACAC,UAAA;QACAC,WAAA;QACAC,WAAA;MACA;MACAC,QAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,QAAA;EACA;EACAC,OAAA;IACA,MAAAD,SAAA;MACA,KAAAnB,OAAA;MACA;QACA;QACA;QACA;QACA,KAAAC,KAAA,IACA;UACAU,EAAA;UACAC,KAAA;UACAL,QAAA;UACAM,cAAA;UACAC,UAAA;UACAO,UAAA;UACAN,WAAA;QACA,GACA;UACAJ,EAAA;UACAC,KAAA;UACAL,QAAA;UACAM,cAAA;UACAC,UAAA;UACAO,UAAA;UACAN,WAAA;QACA,EACA;QACA,KAAAb,KAAA,QAAAD,KAAA,CAAAqB,MAAA;MACA,SAAAC,KAAA;QACA,KAAAC,QAAA,CAAAD,KAAA;MACA;QACA,KAAAvB,OAAA;MACA;IACA;IACAyB,aAAA;MACA,KAAAtB,WAAA;MACA,KAAAgB,QAAA;IACA;IACAO,YAAA;MACA,KAAArB,UAAA;QACAC,MAAA;Q