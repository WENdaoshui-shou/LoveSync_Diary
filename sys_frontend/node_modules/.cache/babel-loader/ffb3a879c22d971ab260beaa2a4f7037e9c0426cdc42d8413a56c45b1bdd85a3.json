{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { getUserInfo } from '@/api/auth';\nexport default {\n  name: 'AdminLayout',\n  data() {\n    return {\n      userInfo: null\n    };\n  },\n  created() {\n    this.loadUserInfo();\n  },\n  methods: {\n    async loadUserInfo() {\n      try {\n        const response = await getUserInfo();\n        if (response.data.code === 200) {\n          this.userInfo = response.data.data;\n        } else {\n          // 如果获取用户信息失败，跳转到登录页\n          localStorage.removeItem('admin_token');\n          this.$router.replace('/login');\n        }\n      } catch (error) {\n        console.error('获取用户信息失败:', error);\n        // 如果获取用户信息失败，跳转到登录页\n        localStorage.removeItem('admin_token');\n        this.$router.replace('/login');\n      }\n    },\n    handleCommand(command) {\n      if (command === 'logout') {\n        this.logout();\n      }\n    },\n    logout() {\n      this.$confirm('确定要退出登录吗？', '确认退出', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        localStorage.removeItem('admin_token');\n        this.$router.push('/login');\n        this.$message.success('退出登录成功');\n      }).catch(() => {\n        // 用户取消\n      });\n    }\n  }\n};","map":{"version":3,"names":["getUserInfo","name","data","userInfo","created","loadUserInfo","methods","response","code","localStorage","removeItem","$router","replace","error","console","handleCommand","command","logout","$confirm","confirmButtonText","cancelButtonText","type","then","push","$message","success","catch"],"sources":["src/views/Layout.vue"],"sourcesContent":["<template>\n  <el-container class=\"layout-container\">\n    <!-- 头部 -->\n    <el-header class=\"layout-header\">\n      <div class=\"header-content\">\n        <div class=\"logo\">\n          <h2>LoveSync 管理后台</h2>\n        </div>\n        <div class=\"header-right\">\n          <el-dropdown @command=\"handleCommand\">\n            <span class=\"el-dropdown-link\">\n              <i class=\"el-icon-user\"></i>\n              {{ userInfo?.name || '管理员' }}\n              <i class=\"el-icon-arrow-down el-icon--right\"></i>\n            </span>\n            <el-dropdown-menu slot=\"dropdown\">\n              <el-dropdown-item command=\"logout\">退出登录</el-dropdown-item>\n            </el-dropdown-menu>\n          </el-dropdown>\n        </div>\n      </div>\n    </el-header>\n\n    <el-container>\n      <!-- 侧边栏 -->\n      <el-aside width=\"200px\" class=\"layout-aside\">\n        <el-menu :default-active=\"$route.path\" class=\"layout-menu\" router background-color=\"#304156\"\n          text-color=\"#bfcbd9\" active-text-color=\"#409EFF\">\n          <el-menu-item index=\"/\">\n            <i class=\"el-icon-s-home\"></i>\n            <span slot=\"title\">首页</span>\n          </el-menu-item>\n\n          <el-menu-item index=\"/users\">\n            <i class=\"el-icon-user\"></i>\n            <span slot=\"title\">用户管理</span>\n          </el-menu-item>\n\n          <el-menu-item index=\"/moments\">\n            <i class=\"el-icon-document\"></i>\n            <span slot=\"title\">动态管理</span>\n          </el-menu-item>\n\n          <el-menu-item index=\"/comments\">\n            <i class=\"el-icon-chat-line-round\"></i>\n            <span slot=\"title\">评论管理</span>\n          </el-menu-item>\n\n          <el-menu-item index=\"/statistics\">\n            <i class=\"el-icon-data-analysis\"></i>\n            <span slot=\"title\">数据统计</span>\n          </el-menu-item>\n        </el-menu>\n      </el-aside>\n\n      <!-- 主内容区 -->\n      <el-main class=\"layout-main\">\n        <router-view />\n      </el-main>\n    </el-container>\n  </el-container>\n</template>\n\n<script>\nimport { getUserInfo } from '@/api/auth'\n\nexport default {\n  name: 'AdminLayout',\n  data() {\n    return {\n      userInfo: null\n    }\n  },\n  created() {\n    this.loadUserInfo()\n  },\n  methods: {\n    async loadUserInfo() {\n      try {\n        const response = await getUserInfo()\n        if (response.data.code === 200) {\n          this.userInfo = response.data.data\n        } else {\n          // 如果获取用户信息失败，跳转到登录页\n          localStorage.removeItem('admin_token')\n          this.$router.replace('/login')\n        }\n      } catch (error) {\n        console.error('获取用户信息失败:', error)\n        // 如果获取用户信息失败，跳转到登录页\n        localStorage.removeItem('admin_token')\n        this.$router.replace('/login')\n      }\n    },\n\n    handleCommand(command) {\n      if (command === 'logout') {\n        this.logout()\n      }\n    },\n\n    logout() {\n      this.$confirm('确定要退出登录吗？', '确认退出', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        localStorage.removeItem('admin_token')\n        this.$router.push('/login')\n        this.$message.success('退出登录成功')\n      }).catch(() => {\n        // 用户取消\n      })\n    }\n  }\n}\n</script>\n\n<style scoped>\n.layout-container {\n  height: 100vh;\n}\n\n.layout-header {\n  background-color: #fff;\n  box-shadow: 0 2px 4px rgba(0, 21, 41, 0.08);\n  padding: 0;\n  z-index: 1000;\n}\n\n.header-content {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  height: 100%;\n  padding: 0 20px;\n}\n\n.logo h2 {\n  margin: 0;\n  color: #303133;\n}\n\n.header-right {\n  display: flex;\n  align-items: center;\n}\n\n.el-dropdown-link {\n  cursor: pointer;\n  color: #409EFF;\n}\n\n.layout-aside {\n  background-color: #304156;\n  overflow: hidden;\n}\n\n.layout-menu {\n  border: none;\n  height: 100%;\n}\n\n.layout-main {\n  background-color: #f5f5f5;\n  padding: 20px;\n  overflow-y: auto;\n}\n</style>"],"mappings":";AAgEA,SAAAA,WAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,QAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,YAAA;EACA;EACAC,OAAA;IACA,MAAAD,aAAA;MACA;QACA,MAAAE,QAAA,SAAAP,WAAA;QACA,IAAAO,QAAA,CAAAL,IAAA,CAAAM,IAAA;UACA,KAAAL,QAAA,GAAAI,QAAA,CAAAL,IAAA,CAAAA,IAAA;QACA;UACA;UACAO,YAAA,CAAAC,UAAA;UACA,KAAAC,OAAA,CAAAC,OAAA;QACA;MACA,SAAAC,KAAA;QACAC,OAAA,CAAAD,KAAA,cAAAA,KAAA;QACA;QACAJ,YAAA,CAAAC,UAAA;QACA,KAAAC,OAAA,CAAAC,OAAA;MACA;IACA;IAEAG,cAAAC,OAAA;MACA,IAAAA,OAAA;QACA,KAAAC,MAAA;MACA;IACA;IAEAA,OAAA;MACA,KAAAC,QAAA;QACAC,iBAAA;QACAC,gBAAA;QACAC,IAAA;MACA,GAAAC,IAAA;QACAb,YAAA,CAAAC,UAAA;QACA,KAAAC,OAAA,CAAAY,IAAA;QACA,KAAAC,QAAA,CAAAC,OAAA;MACA,GAAAC,KAAA;QACA;MAAA,CACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}