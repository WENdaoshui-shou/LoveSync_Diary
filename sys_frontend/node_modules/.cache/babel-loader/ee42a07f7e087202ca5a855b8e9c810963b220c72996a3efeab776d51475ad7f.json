{"ast":null,"code":"export default {\n  name: 'CommunityTopics',\n  data() {\n    return {\n      statistics: {\n        totalTopics: 0,\n        activeTopics: 0,\n        hotTopics: 0,\n        totalDiscussions: 0\n      },\n      topics: [],\n      searchKeyword: '',\n      filterStatus: '',\n      currentPage: 1,\n      pageSize: 10,\n      total: 0,\n      loading: false\n    };\n  },\n  created() {\n    this.loadData();\n    this.loadStatistics();\n  },\n  methods: {\n    loadData() {\n      // TODO: 加载话题数据\n    },\n    loadStatistics() {\n      // TODO: 加载统计数据\n    },\n    createTopic() {\n      // TODO: 创建话题\n    },\n    refreshData() {\n      this.loadData();\n      this.loadStatistics();\n    },\n    searchTopics() {\n      this.currentPage = 1;\n      this.loadData();\n    },\n    viewTopic(topic) {\n      // TODO: 查看话题\n    },\n    editTopic(topic) {\n      // TODO: 编辑话题\n    },\n    closeTopic(topic) {\n      // TODO: 关闭话题\n    },\n    openTopic(topic) {\n      // TODO: 开启话题\n    },\n    handleSizeChange(val) {\n      this.pageSize = val;\n      this.loadData();\n    },\n    handleCurrentChange(val) {\n      this.currentPage = val;\n      this.loadData();\n    },\n    getStatusType(status) {\n      const types = {\n        'active': 'success',\n        'hot': 'danger',\n        'closed': 'info'\n      };\n      return types[status] || 'info';\n    },\n    getStatusText(status) {\n      const texts = {\n        'active': '活跃',\n        'hot': '热门',\n        'closed': '已关闭'\n      };\n      return texts[status] || status;\n    },\n    getHeatType(heatLevel) {\n      const types = {\n        1: 'info',\n        2: 'warning',\n        3: 'danger'\n      };\n      return types[heatLevel] || 'info';\n    },\n    getHeatText(heatLevel) {\n      const texts = {\n        1: '普通',\n        2: '热门',\n        3: '火爆'\n      };\n      return texts[heatLevel] || '未知';\n    }\n  }\n};","map":{"version":3,"names":["name","data","statistics","totalTopics","activeTopics","hotTopics","totalDiscussions","topics","searchKeyword","filterStatus","currentPage","pageSize","total","loading","created","loadData","loadStatistics","methods","createTopic","refreshData","searchTopics","viewTopic","topic","editTopic","closeTopic","openTopic","handleSizeChange","val","handleCurrentChange","getStatusType","status","types","getStatusText","texts","getHeatType","heatLevel","getHeatText"],"sources":["src/views/community/CommunityTopics.vue"],"sourcesContent":["<template>\n  <div class=\"topic-management\">\n    <h1>热门话题管理</h1>\n    <p>管理社区热门话题和讨论</p>\n\n    <!-- 话题统计 -->\n    <div class=\"stats-container\">\n      <el-row :gutter=\"20\">\n        <el-col :span=\"6\">\n          <el-card class=\"stat-card\">\n            <div class=\"stat-content\">\n              <div class=\"stat-number\">{{ statistics.totalTopics || 0 }}</div>\n              <div class=\"stat-label\">总话题数</div>\n            </div>\n          </el-card>\n        </el-col>\n        <el-col :span=\"6\">\n          <el-card class=\"stat-card\">\n            <div class=\"stat-content\">\n              <div class=\"stat-number text-success\">{{ statistics.activeTopics || 0 }}</div>\n              <div class=\"stat-label\">活跃话题</div>\n            </div>\n          </el-card>\n        </el-col>\n        <el-col :span=\"6\">\n          <el-card class=\"stat-card\">\n            <div class=\"stat-content\">\n              <div class=\"stat-number text-warning\">{{ statistics.hotTopics || 0 }}</div>\n              <div class=\"stat-label\">热门话题</div>\n            </div>\n          </el-card>\n        </el-col>\n        <el-col :span=\"6\">\n          <el-card class=\"stat-card\">\n            <div class=\"stat-content\">\n              <div class=\"stat-number text-info\">{{ statistics.totalDiscussions || 0 }}</div>\n              <div class=\"stat-label\">总讨论数</div>\n            </div>\n          </el-card>\n        </el-col>\n      </el-row>\n    </div>\n\n    <!-- 操作栏 -->\n    <div class=\"action-bar\">\n      <el-button type=\"primary\" @click=\"createTopic\">\n        <i class=\"el-icon-plus\"></i> 创建话题\n      </el-button>\n      <el-button @click=\"refreshData\">\n        <i class=\"el-icon-refresh\"></i> 刷新\n      </el-button>\n    </div>\n\n    <!-- 话题列表 -->\n    <el-card>\n      <div slot=\"header\" class=\"card-header\">\n        <span>话题列表</span>\n        <div class=\"header-actions\">\n          <el-input v-model=\"searchKeyword\" placeholder=\"搜索话题\" prefix-icon=\"el-icon-search\"\n            style=\"width: 200px; margin-right: 10px\" @keyup.enter=\"searchTopics\"></el-input>\n          <el-select v-model=\"filterStatus\" placeholder=\"状态筛选\" style=\"width: 120px; margin-right: 10px\">\n            <el-option label=\"全部\" value=\"\"></el-option>\n            <el-option label=\"活跃\" value=\"active\"></el-option>\n            <el-option label=\"热门\" value=\"hot\"></el-option>\n            <el-option label=\"已关闭\" value=\"closed\"></el-option>\n          </el-select>\n          <el-button type=\"primary\" size=\"small\" @click=\"searchTopics\">搜索</el-button>\n        </div>\n      </div>\n\n      <div class=\"topic-list\">\n        <div v-if=\"topics.length === 0\" class=\"empty-state\">\n          <i class=\"el-icon-chat-dot-round\"></i>\n          <p>暂无话题数据</p>\n        </div>\n\n        <div v-else class=\"topic-grid\">\n          <div v-for=\"topic in topics\" :key=\"topic.id\" class=\"topic-card\">\n            <div class=\"topic-header\">\n              <div class=\"topic-icon\">\n                <i :class=\"topic.icon || 'el-icon-chat-dot-round'\"></i>\n              </div>\n              <div class=\"topic-info\">\n                <h4>{{ topic.title }}</h4>\n                <p>{{ topic.description }}</p>\n                <div class=\"topic-meta\">\n                  <el-tag :type=\"getStatusType(topic.status)\" size=\"mini\">\n                    {{ getStatusText(topic.status) }}\n                  </el-tag>\n                  <el-tag :type=\"getHeatType(topic.heat_level)\" size=\"mini\">\n                    {{ getHeatText(topic.heat_level) }}\n                  </el-tag>\n                  <span class=\"topic-stats\">\n                    <i class=\"el-icon-view\"></i> {{ topic.view_count }}\n                    <i class=\"el-icon-chat-dot-round\"></i> {{ topic.discussion_count }}\n                    <i class=\"el-icon-thumb\"></i> {{ topic.like_count }}\n                  </span>\n                </div>\n              </div>\n            </div>\n\n            <div class=\"topic-actions\">\n              <el-button type=\"text\" size=\"mini\" @click=\"viewTopic(topic)\">查看</el-button>\n              <el-button type=\"text\" size=\"mini\" @click=\"editTopic(topic)\">编辑</el-button>\n              <el-button v-if=\"topic.status === 'active'\" type=\"text\" size=\"mini\" @click=\"closeTopic(topic)\">\n                关闭\n              </el-button>\n              <el-button v-else type=\"text\" size=\"mini\" @click=\"openTopic(topic)\">\n                开启\n              </el-button>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- 分页 -->\n      <div class=\"pagination-container\">\n        <el-pagination @size-change=\"handleSizeChange\" @current-change=\"handleCurrentChange\" :current-page=\"currentPage\"\n          :page-sizes=\"[10, 20, 50, 100]\" :page-size=\"pageSize\" layout=\"total, sizes, prev, pager, next, jumper\"\n          :total=\"total\"></el-pagination>\n      </div>\n    </el-card>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'CommunityTopics',\n  data() {\n    return {\n      statistics: {\n        totalTopics: 0,\n        activeTopics: 0,\n        hotTopics: 0,\n        totalDiscussions: 0\n      },\n      topics: [],\n      searchKeyword: '',\n      filterStatus: '',\n      currentPage: 1,\n      pageSize: 10,\n      total: 0,\n      loading: false\n    }\n  },\n  created() {\n    this.loadData()\n    this.loadStatistics()\n  },\n  methods: {\n    loadData() {\n      // TODO: 加载话题数据\n    },\n    \n    loadStatistics() {\n      // TODO: 加载统计数据\n    },\n    \n    createTopic() {\n      // TODO: 创建话题\n    },\n\n    refreshData() {\n      this.loadData()\n      this.loadStatistics()\n    },\n\n    searchTopics() {\n      this.currentPage = 1\n      this.loadData()\n    },\n\n    viewTopic(topic) {\n      // TODO: 查看话题\n    },\n\n    editTopic(topic) {\n      // TODO: 编辑话题\n    },\n\n    closeTopic(topic) {\n      // TODO: 关闭话题\n    },\n\n    openTopic(topic) {\n      // TODO: 开启话题\n    },\n\n    handleSizeChange(val) {\n      this.pageSize = val\n      this.loadData()\n    },\n\n    handleCurrentChange(val) {\n      this.currentPage = val\n      this.loadData()\n    },\n\n    getStatusType(status) {\n      const types = {\n        'active': 'success',\n        'hot': 'danger',\n        'closed': 'info'\n      }\n      return types[status] || 'info'\n    },\n\n    getStatusText(status) {\n      const texts = {\n        'active': '活跃',\n        'hot': '热门',\n        'closed': '已关闭'\n      }\n      return texts[status] || status\n    },\n\n    getHeatType(heatLevel) {\n      const types = {\n        1: 'info',\n        2: 'warning',\n        3: 'danger'\n      }\n      return types[heatLevel] || 'info'\n    },\n\n    getHeatText(heatLevel) {\n      const texts = {\n        1: '普通',\n        2: '热门',\n        3: '火爆'\n      }\n      return texts[heatLevel] || '未知'\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.community-topics {\n  padding: 20px;\n\n  h1 {\n    color: #303133;\n    margin-bottom: 10px;\n  }\n\n  p {\n    color: #909399;\n    margin-bottom: 30px;\n  }\n}\n\n.stats-container {\n  margin-bottom: 30px;\n}\n\n.stat-card {\n  text-align: center;\n\n  .stat-content {\n    padding: 20px 0;\n\n    .stat-number {\n      font-size: 32px;\n      font-weight: bold;\n      color: #303133;\n      margin-bottom: 10px;\n\n      &.text-success {\n        color: #67C23A;\n      }\n\n      &.text-warning {\n        color: #E6A23C;\n      }\n\n      &.text-info {\n        color: #409EFF;\n      }\n    }\n\n    .stat-label {\n      font-size: 14px;\n      color: #909399;\n    }\n  }\n}\n\n.action-bar {\n  margin-bottom: 20px;\n}\n\n.card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.empty-state {\n  text-align: center;\n  padding: 60px 20px;\n  color: #909399;\n\n  i {\n    font-size: 64px;\n    margin-bottom: 20px;\n    display: block;\n  }\n\n  p {\n    margin: 0;\n    font-size: 16px;\n  }\n}\n\n.topic-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));\n  gap: 20px;\n  margin-top: 20px;\n}\n\n.topic-card {\n  background: #fff;\n  border-radius: 8px;\n  padding: 20px;\n  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);\n  transition: all 0.3s ease;\n\n  &:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);\n  }\n\n  .topic-header {\n    display: flex;\n    align-items: flex-start;\n    gap: 15px;\n    margin-bottom: 15px;\n\n    .topic-icon {\n      font-size: 32px;\n      color: #409EFF;\n      width: 40px;\n      text-align: center;\n    }\n\n    .topic-info {\n      flex: 1;\n\n      h4 {\n        margin: 0 0 8px 0;\n        color: #303133;\n        font-size: 16px;\n      }\n\n      p {\n        margin: 0 0 10px 0;\n        color: #606266;\n        font-size: 14px;\n        line-height: 1.5;\n      }\n\n      .topic-meta {\n        display: flex;\n        align-items: center;\n        gap: 10px;\n        flex-wrap: wrap;\n\n        .topic-stats {\n          font-size: 12px;\n          color: #909399;\n          display: flex;\n          align-items: center;\n          gap: 15px;\n\n          i {\n            margin-right: 3px;\n          }\n        }\n      }\n    }\n  }\n\n  .topic-actions {\n    display: flex;\n    justify-content: flex-end;\n    gap: 10px;\n  }\n}\n\n.pagination-container {\n  margin-top: 20px;\n  text-align: right;\n}\n</style>"],"mappings":"AA8HA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,UAAA;QACAC,WAAA;QACAC,YAAA;QACAC,SAAA;QACAC,gBAAA;MACA;MACAC,MAAA;MACAC,aAAA;MACAC,YAAA;MACAC,WAAA;MACAC,QAAA;MACAC,KAAA;MACAC,OAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,QAAA;IACA,KAAAC,cAAA;EACA;EACAC,OAAA;IACAF,SAAA;MACA;IAAA,CACA;IAEAC,eAAA;MACA;IAAA,CACA;IAEAE,YAAA;MACA;IAAA,CACA;IAEAC,YAAA;MACA,KAAAJ,QAAA;MACA,KAAAC,cAAA;IACA;IAEAI,aAAA;MACA,KAAAV,WAAA;MACA,KAAAK,QAAA;IACA;IAEAM,UAAAC,KAAA;MACA;IAAA,CACA;IAEAC,UAAAD,KAAA;MACA;IAAA,CACA;IAEAE,WAAAF,KAAA;MACA;IAAA,CACA;IAEAG,UAAAH,KAAA;MACA;IAAA,CACA;IAEAI,iBAAAC,GAAA;MACA,KAAAhB,QAAA,GAAAgB,GAAA;MACA,KAAAZ,QAAA;IACA;IAEAa,oBAAAD,GAAA;MACA,KAAAjB,WAAA,GAAAiB,GAAA;MACA,KAAAZ,QAAA;IACA;IAEAc,cAAAC,MAAA;MACA,MAAAC,KAAA;QACA;QACA;QACA;MACA;MACA,OAAAA,KAAA,CAAAD,MAAA;IACA;IAEAE,cAAAF,MAAA;MACA,MAAAG,KAAA;QACA;QACA;QACA;MACA;MACA,OAAAA,KAAA,CAAAH,MAAA,KAAAA,MAAA;IACA;IAEAI,YAAAC,SAAA;MACA,MAAAJ,KAAA;QACA;QACA;QACA;MACA;MACA,OAAAA,KAAA,CAAAI,SAAA;IACA;IAEAC,YAAAD,SAAA;MACA,MAAAF,KAAA;QACA;QACA;QACA;MACA;MACA,OAAAA,KAAA,CAAAE,SAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}