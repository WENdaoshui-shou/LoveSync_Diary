{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { login } from '@/api/auth';\nexport default {\n  name: 'AdminLogin',\n  data() {\n    return {\n      loginForm: {\n        username: '',\n        password: ''\n      },\n      loginRules: {\n        username: [{\n          required: true,\n          message: '请输入用户名',\n          trigger: 'blur'\n        }],\n        password: [{\n          required: true,\n          message: '请输入密码',\n          trigger: 'blur'\n        }]\n      },\n      loading: false\n    };\n  },\n  created() {\n    // 检查是否已经登录，如果已登录则跳转到首页\n    const token = localStorage.getItem('admin_token');\n    if (token) {\n      this.$router.replace('/');\n    }\n  },\n  methods: {\n    async handleLogin() {\n      try {\n        const valid = await this.$refs.loginForm.validate();\n        if (!valid) {\n          return;\n        }\n        this.loading = true;\n        console.log('开始登录，用户名:', this.loginForm.username);\n        const response = await login(this.loginForm);\n        console.log('登录响应:', response);\n        const token = response.data.access;\n        if (token) {\n          console.log('获取到token，准备保存和跳转');\n          localStorage.setItem('admin_token', token);\n          this.$message.success('登录成功');\n          console.log('准备跳转到首页');\n          try {\n            await this.$router.push('/');\n            console.log('跳转成功');\n          } catch (err) {\n            console.error('跳转失败:', err);\n            if (err.name === 'NavigationDuplicated') {\n              console.log('导航重复，忽略错误');\n            } else {\n              this.$message.error('跳转失败');\n            }\n          }\n        } else {\n          console.error('未获取到token');\n          this.$message.error('登录失败：未获取到token');\n        }\n      } catch (error) {\n        console.error('登录失败:', error);\n        this.$message.error('登录失败，请检查用户名和密码');\n      } finally {\n        this.loading = false;\n      }\n    }\n  }\n};","map":{"version":3,"names":["