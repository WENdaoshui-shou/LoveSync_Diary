sync handleLogin() {\n      try {\n        const valid = await this.$refs.loginForm.validate()\n        if (!valid) {\n          return\n        }\n\n        this.loading = true\n        console.log('开始登录，用户名:', this.loginForm.username)\n\n        const response = await login(this.loginForm)\n        console.log('登录响应:', response)\n\n        const token = response.data.access\n        if (token) {\n          console.log('获取到token，准备保存和跳转')\n          localStorage.setItem('admin_token', token)\n          this.$message.success('登录成功')\n\n          console.log('准备跳转到首页')\n          try {\n            await this.$router.push('/')\n            console.log('跳转成功')\n          } catch (err) {\n            console.error('跳转失败:', err)\n            if (err.name === 'NavigationDuplicated') {\n              console.log('导航重复，忽略错误')\n            } else {\n              this.$message.error('跳转失败')\n            }\n          }\n        } else {\n          console.error('未获取到token')\n          this.$message.error('登录失败：未获取到token')\n        }\n      } catch (error) {\n        console.error('登录失败:', error)\n        this.$message.error('登录失败，请检查用户名和密码')\n      } finally {\n        this.loading = false\n      }\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.login-container {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  height: 100vh;\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n}\n\n.login-card {\n  width: 400px;\n  box-shadow: 0 2px 12px 0 rgba(0, 0, 0, 0.1);\n}\n\n.login-header {\n  text-align: center;\n\n  h2 {\n    margin: 0;\n    color: #303133;\n    font-weight: 400;\n  }\n}\n</style>"],"mappings":";AAyBA,SAAAA,KAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,SAAA;QACAC,QAAA;QACAC,QAAA;MACA;MACAC,UAAA;QACAF,QAAA,GACA;UAAAG,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAJ,QAAA,GACA;UAAAE,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MAEA;MACAC,OAAA;IACA;EACA;EACAC,QAAA;IACA;IACA,MAAAC,KAAA,GAAAC,YAAA,CAAAC,OAAA;IACA,IAAAF,KAAA;MAEA,KAAAG,OAAA,CAA