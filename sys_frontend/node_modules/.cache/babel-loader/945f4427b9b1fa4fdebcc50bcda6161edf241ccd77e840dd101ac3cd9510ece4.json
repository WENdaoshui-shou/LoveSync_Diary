{"ast":null,"code":"export default {\n  name: 'CommunityAchievements',\n  data() {\n    return {\n      stats: {\n        totalAchievements: 25,\n        userAchievements: 156,\n        completionRate: '12%',\n        activeUsers: 89\n      },\n      achievements: [{\n        id: 1,\n        name: '初次分享',\n        description: '分享您的第一个动态',\n        icon: 'el-icon-share',\n        difficulty: 1,\n        points: 10\n      }, {\n        id: 2,\n        name: '社交达人',\n        description: '获得100个点赞',\n        icon: 'el-icon-thumb',\n        difficulty: 2,\n        points: 50\n      }, {\n        id: 3,\n        name: '社区贡献者',\n        description: '参与10次社区活动',\n        icon: 'el-icon-star',\n        difficulty: 3,\n        points: 100\n      }]\n    };\n  },\n  methods: {\n    createAchievement() {\n      this.$message.info('创建成就功能开发中...');\n    },\n    editAchievement(achievement) {\n      this.$message.info(`编辑成就: ${achievement.name}`);\n    },\n    viewAchievementUsers(achievement) {\n      this.$message.info(`查看获得成就的用户: ${achievement.name}`);\n    },\n    getDifficultyType(difficulty) {\n      const types = {\n        1: 'success',\n        2: 'warning',\n        3: 'danger'\n      };\n      return types[difficulty] || 'info';\n    },\n    getDifficultyText(difficulty) {\n      const texts = {\n        1: '简单',\n        2: '中等',\n        3: '困难'\n      };\n      return texts[difficulty] || '未知';\n    }\n  }\n};","map":{"version":3,"names":["name","data","stats","totalAchievements","userAchievements","completionRate","activeUsers","achievements","id","description","icon","difficulty","points","methods","createAchievement","$message","info","editAchievement","achievement","viewAchievementUsers","getDifficultyType","types","getDifficultyText","texts"],"sources":["src/views/community/CommunityAchievements.vue"],"sourcesContent":["<template>\n  <div class=\"achievement-management\">\n    <h1>成就系统管理</h1>\n    <p>管理用户成就、徽章和奖励系统</p>\n    \n    <!-- 成就统计 -->\n    <div class=\"stats-container\">\n      <el-row :gutter=\"20\">\n        <el-col :span=\"6\">\n          <el-card class=\"stat-card\">\n            <div class=\"stat-content\">\n              <div class=\"stat-number\">{{ statistics.totalAchievements || 0 }}</div>\n              <div class=\"stat-label\">总成就数</div>\n            </div>\n          </el-card>\n        </el-col>\n        <el-col :span=\"6\">\n          <el-card class=\"stat-card\">\n            <div class=\"stat-content\">\n              <div class=\"stat-number text-success\">{{ stats.userAchievements || 0 }}</div>\n              <div class=\"stat-label\">用户获得</div>\n            </div>\n          </el-card>\n        </el-col>\n        <el-col :span=\"6\">\n          <el-card class=\"stat-card\">\n            <div class=\"stat-content\">\n              <div class=\"stat-number text-warning\">{{ stats.completionRate || '0%' }}</div>\n              <div class=\"stat-label\">完成率</div>\n            </div>\n          </el-card>\n        </el-col>\n        <el-col :span=\"6\">\n          <el-card class=\"stat-card\">\n            <div class=\"stat-content\">\n              <div class=\"stat-number text-info\">{{ stats.activeUsers || 0 }}</div>\n              <div class=\"stat-label\">活跃用户数</div>\n            </div>\n          </el-card>\n        </el-col>\n      </el-row>\n    </div>\n\n    <!-- 成就列表 -->\n    <el-card>\n      <div slot=\"header\" class=\"card-header\">\n        <span>成就列表</span>\n        <el-button type=\"primary\" size=\"small\" @click=\"createAchievement\">\n          <i class=\"el-icon-plus\"></i> 创建成就\n        </el-button>\n      </div>\n      \n      <div class=\"achievement-list\">\n        <div v-if=\"achievements.length === 0\" class=\"empty-state\">\n          <i class=\"el-icon-trophy\"></i>\n          <p>暂无成就数据</p>\n        </div>\n        \n        <div v-else class=\"achievement-grid\">\n          <div v-for=\"achievement in achievements\" :key=\"achievement.id\" class=\"achievement-card\">\n            <div class=\"achievement-icon\">\n              <i :class=\"achievement.icon || 'el-icon-trophy'\"></i>\n            </div>\n            <div class=\"achievement-info\">\n              <h4>{{ achievement.name }}</h4>\n              <p>{{ achievement.description }}</p>\n              <div class=\"achievement-meta\">\n                <el-tag :type=\"getDifficultyType(achievement.difficulty)\" size=\"mini\">\n                  {{ getDifficultyText(achievement.difficulty) }}\n                </el-tag>\n                <span class=\"achievement-points\">{{ achievement.points }} 积分</span>\n              </div>\n            </div>\n            <div class=\"achievement-actions\">\n              <el-button type=\"text\" size=\"mini\" @click=\"editAchievement(achievement)\">编辑</el-button>\n              <el-button type=\"text\" size=\"mini\" @click=\"viewAchievementUsers(achievement)\">查看用户</el-button>\n            </div>\n          </div>\n        </div>\n      </div>\n    </el-card>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'CommunityAchievements',\n  data() {\n    return {\n      stats: {\n        totalAchievements: 25,\n        userAchievements: 156,\n        completionRate: '12%',\n        activeUsers: 89\n      },\n      achievements: [\n        {\n          id: 1,\n          name: '初次分享',\n          description: '分享您的第一个动态',\n          icon: 'el-icon-share',\n          difficulty: 1,\n          points: 10\n        },\n        {\n          id: 2,\n          name: '社交达人',\n          description: '获得100个点赞',\n          icon: 'el-icon-thumb',\n          difficulty: 2,\n          points: 50\n        },\n        {\n          id: 3,\n          name: '社区贡献者',\n          description: '参与10次社区活动',\n          icon: 'el-icon-star',\n          difficulty: 3,\n          points: 100\n        }\n      ]\n    }\n  },\n  methods: {\n    createAchievement() {\n      this.$message.info('创建成就功能开发中...')\n    },\n    \n    editAchievement(achievement) {\n      this.$message.info(`编辑成就: ${achievement.name}`)\n    },\n    \n    viewAchievementUsers(achievement) {\n      this.$message.info(`查看获得成就的用户: ${achievement.name}`)\n    },\n    \n    getDifficultyType(difficulty) {\n      const types = {\n        1: 'success',\n        2: 'warning',\n        3: 'danger'\n      }\n      return types[difficulty] || 'info'\n    },\n    \n    getDifficultyText(difficulty) {\n      const texts = {\n        1: '简单',\n        2: '中等',\n        3: '困难'\n      }\n      return texts[difficulty] || '未知'\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.community-achievements {\n  padding: 20px;\n\n  h1 {\n    color: #303133;\n    margin-bottom: 10px;\n  }\n\n  p {\n    color: #909399;\n    margin-bottom: 30px;\n  }\n}\n\n.stats-container {\n  margin-bottom: 30px;\n}\n\n.stat-card {\n  text-align: center;\n\n  .stat-content {\n    padding: 20px 0;\n\n    .stat-number {\n      font-size: 32px;\n      font-weight: bold;\n      color: #303133;\n      margin-bottom: 10px;\n\n      &.text-success {\n        color: #67C23A;\n      }\n\n      &.text-warning {\n        color: #E6A23C;\n      }\n\n      &.text-info {\n        color: #409EFF;\n      }\n    }\n\n    .stat-label {\n      font-size: 14px;\n      color: #909399;\n    }\n  }\n}\n\n.card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.empty-state {\n  text-align: center;\n  padding: 60px 20px;\n  color: #909399;\n\n  i {\n    font-size: 64px;\n    margin-bottom: 20px;\n    display: block;\n  }\n\n  p {\n    margin: 0;\n    font-size: 16px;\n  }\n}\n\n.achievement-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));\n  gap: 20px;\n  margin-top: 20px;\n}\n\n.achievement-card {\n  background: #fff;\n  border-radius: 8px;\n  padding: 20px;\n  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);\n  display: flex;\n  align-items: center;\n  gap: 15px;\n  transition: all 0.3s ease;\n\n  &:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);\n  }\n\n  .achievement-icon {\n    font-size: 48px;\n    color: #409EFF;\n    width: 60px;\n    text-align: center;\n  }\n\n  .achievement-info {\n    flex: 1;\n\n    h4 {\n      margin: 0 0 8px 0;\n      color: #303133;\n      font-size: 16px;\n    }\n\n    p {\n      margin: 0 0 10px 0;\n      color: #606266;\n      font-size: 14px;\n      line-height: 1.5;\n    }\n\n    .achievement-meta {\n      display: flex;\n      align-items: center;\n      gap: 10px;\n\n      .achievement-points {\n        font-size: 12px;\n        color: #909399;\n        font-weight: bold;\n      }\n    }\n  }\n\n  .achievement-actions {\n    display: flex;\n    flex-direction: column;\n    gap: 5px;\n  }\n}\n</style>"],"mappings":"AAqFA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,KAAA;QACAC,iBAAA;QACAC,gBAAA;QACAC,cAAA;QACAC,WAAA;MACA;MACAC,YAAA,GACA;QACAC,EAAA;QACAR,IAAA;QACAS,WAAA;QACAC,IAAA;QACAC,UAAA;QACAC,MAAA;MACA,GACA;QACAJ,EAAA;QACAR,IAAA;QACAS,WAAA;QACAC,IAAA;QACAC,UAAA;QACAC,MAAA;MACA,GACA;QACAJ,EAAA;QACAR,IAAA;QACAS,WAAA;QACAC,IAAA;QACAC,UAAA;QACAC,MAAA;MACA;IAEA;EACA;EACAC,OAAA;IACAC,kBAAA;MACA,KAAAC,QAAA,CAAAC,IAAA;IACA;IAEAC,gBAAAC,WAAA;MACA,KAAAH,QAAA,CAAAC,IAAA,UAAAE,WAAA,CAAAlB,IAAA;IACA;IAEAmB,qBAAAD,WAAA;MACA,KAAAH,QAAA,CAAAC,IAAA,eAAAE,WAAA,CAAAlB,IAAA;IACA;IAEAoB,kBAAAT,UAAA;MACA,MAAAU,KAAA;QACA;QACA;QACA;MACA;MACA,OAAAA,KAAA,CAAAV,UAAA;IACA;IAEAW,kBAAAX,UAAA;MACA,MAAAY,KAAA;QACA;QACA;QACA;MACA;MACA,OAAAA,KAAA,CAAAZ,UAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}