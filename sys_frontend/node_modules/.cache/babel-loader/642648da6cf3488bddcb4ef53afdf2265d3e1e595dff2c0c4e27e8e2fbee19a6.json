{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nimport { getBanners, createBanner, updateBanner, deleteBanner } from '@/api/mall';\nexport default {\n  name: 'BannerList',\n  data() {\n    return {\n      loading: false,\n      banners: [],\n      searchForm: {\n        title: ''\n      },\n      pagination: {\n        current: 1,\n        size: 10,\n        total: 0\n      },\n      dialogVisible: false,\n      dialogTitle: '',\n      form: {\n        id: '',\n        title: '',\n        link_url: '',\n        sort_order: 0,\n        is_active: true\n      }\n    };\n  },\n  mounted() {\n    this.fetchBanners();\n  },\n  methods: {\n    fetchBanners() {\n      this.loading = true;\n      const params = {\n        page: this.pagination.current,\n        page_size: this.pagination.size,\n        search: this.searchForm.title\n      };\n      getBanners(params).then(response => {\n        // 后端直接返回数组格式，不是 { results: [...], count: number } 格式\n        // 映射后端字段到前端字段\n        this.banners = response.data.map(item => ({\n          ...item,\n          link_url: item.link,\n          // 后端字段是link，前端使用link_url\n          sort_order: item.sort // 后端字段是sort，前端使用sort_order\n        }));\n        this.pagination.total = response.data.length;\n      }).catch(error => {\n        this.$message.error('获取Banner列表失败: ' + error.message);\n      }).finally(() => {\n        this.loading = false;\n      });\n    },\n    handleAdd() {\n      this.dialogTitle = '添加Banner';\n      this.form = {\n        id: '',\n        title: '',\n        link_url: '',\n        sort_order: 0,\n        is_active: true\n      };\n      this.dialogVisible = true;\n    },\n    handleEdit(row) {\n      this.dialogTitle = '编辑Banner';\n      this.form = {\n        ...row\n      };\n      this.dialogVisible = true;\n    },\n    handleSubmit() {\n      if (!this.form.title) {\n        this.$message.error('请输入Banner名称');\n        return;\n      }\n      if (!this.form.link_url) {\n        this.$message.error('请输入链接地址');\n        return;\n      }\n\n      // 准备提交数据，将前端字段映射回后端字段\n      const submitData = {\n        title: this.form.title,\n        link: this.form.link_url,\n        // 前端使用link_url，后端需要link\n        sort: this.form.sort_order,\n        // 前端使用sort_order，后端需要sort\n        is_active: this.form.is_active ? 1 : 0 // 前端使用布尔值，后端需要数字\n      };\n      const request = this.form.id ? updateBanner(this.form.id, submitData) : createBanner(submitData);\n      request.then(() => {\n        this.$message.success(this.form.id ? '更新Banner成功' : '添加Banner成功');\n        this.dialogVisible = false;\n        this.fetchBanners();\n      }).catch(error => {\n        this.$message.error((this.form.id ? '更新Banner' : '添加Banner') + '失败: ' + error.message);\n      });\n    },\n    handleDelete(id) {\n      this.$confirm('确定要删除这个Banner吗？', '警告', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        deleteBanner(id).then(() => {\n          this.$message.success('删除Banner成功');\n          this.fetchBanners();\n        }).catch(error => {\n          this.$message.error('删除Banner失败: ' + error.message);\n        });\n      }).catch(() => {});\n    },\n    resetForm() {\n      this.searchForm = {\n        title: ''\n      };\n      this.fetchBanners();\n    },\n    handleSizeChange(size) {\n      this.pagination.size = size;\n      this.fetchBanners();\n    },\n    handleCurrentChange(current) {\n      this.pagination.current = current;\n      this.fetchBanners();\n    }\n  }\n};","map":{"version":3,"names":["getBanners","createBanner","updateBanner","deleteBanner","name","data","loading","banners","searchForm","title","pagination","current","size","total","dialogVisible","dialogTitle","form","id","link_url","sort_order","is_active","mounted","fetchBanners","methods","params","page","page_size","search","then","response","map","item","link","sort","length","catch","error","$message","message","finally","handleAdd","handleEdit","row","handleSubmit","submitData","request","success","handleDelete","$confirm","confirmButtonText","cancelButtonText","type","resetForm","handleSizeChange","handleCurrentChange"],"sources":["src/views/mall/content/BannerList.vue"],"sourcesContent":["<template>\n  <div class=\"banner-management\">\n    <el-card shadow=\"never\">\n      <div slot=\"header\" class=\"card-header\">\n        <span>Banner管理</span>\n        <el-button type=\"primary\" size=\"small\" @click=\"handleAdd\">\n          <i class=\"el-icon-plus\"></i> 添加Banner\n        </el-button>\n      </div>\n      \n      <el-form :inline=\"true\" :model=\"searchForm\" class=\"search-form\">\n        <el-form-item label=\"Banner名称\">\n          <el-input v-model=\"searchForm.title\" placeholder=\"请输入Banner名称\" clearable />\n        </el-form-item>\n        <el-form-item>\n          <el-button type=\"primary\" @click=\"fetchBanners\">\n            <i class=\"el-icon-search\"></i> 搜索\n          </el-button>\n          <el-button @click=\"resetForm\">\n            <i class=\"el-icon-refresh\"></i> 重置\n          </el-button>\n        </el-form-item>\n      </el-form>\n      \n      <el-table v-loading=\"loading\" :data=\"banners\" style=\"width: 100%\">\n        <el-table-column prop=\"id\" label=\"Banner ID\" width=\"80\" />\n        <el-table-column prop=\"title\" label=\"Banner名称\" />\n        <el-table-column prop=\"link_url\" label=\"链接地址\" />\n        <el-table-column prop=\"sort_order\" label=\"排序\" width=\"80\" />\n        <el-table-column label=\"状态\" width=\"100\">\n          <template slot-scope=\"scope\">\n            <el-tag :type=\"scope.row.is_active === 1 ? 'success' : 'danger'\">\n              {{ scope.row.is_active === 1 ? '启用' : '禁用' }}\n            </el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"created_at\" label=\"创建时间\" width=\"180\" />\n        <el-table-column label=\"操作\" width=\"150\" fixed=\"right\">\n          <template slot-scope=\"scope\">\n            <el-button type=\"primary\" size=\"small\" @click=\"handleEdit(scope.row)\">\n              <i class=\"el-icon-edit\"></i> 编辑\n            </el-button>\n            <el-button type=\"danger\" size=\"small\" @click=\"handleDelete(scope.row.id)\">\n              <i class=\"el-icon-delete\"></i> 删除\n            </el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n      \n      <div class=\"pagination-container\">\n        <el-pagination\n          :current-page=\"pagination.current\"\n          :page-size=\"pagination.size\"\n          :page-sizes=\"[10, 20, 50, 100]\"\n          layout=\"total, sizes, prev, pager, next, jumper\"\n          :total=\"pagination.total\"\n          @size-change=\"handleSizeChange\"\n          @current-change=\"handleCurrentChange\"\n        />\n      </div>\n    </el-card>\n    \n    <!-- 添加/编辑对话框 -->\n    <el-dialog :title=\"dialogTitle\" v-model=\"dialogVisible\" width=\"600px\">\n      <el-form :model=\"form\" label-width=\"100px\">\n        <el-form-item label=\"Banner名称\" required>\n          <el-input v-model=\"form.title\" placeholder=\"请输入Banner名称\" />\n        </el-form-item>\n        <el-form-item label=\"链接地址\" required>\n          <el-input v-model=\"form.link_url\" placeholder=\"请输入链接地址\" />\n        </el-form-item>\n        <el-form-item label=\"排序\">\n          <el-input-number v-model=\"form.sort_order\" :min=\"0\" :max=\"999\" />\n        </el-form-item>\n        <el-form-item label=\"状态\">\n          <el-switch v-model=\"form.is_active\" />\n        </el-form-item>\n      </el-form>\n      <template slot=\"footer\">\n        <span class=\"dialog-footer\">\n          <el-button @click=\"dialogVisible = false\">取消</el-button>\n          <el-button type=\"primary\" @click=\"handleSubmit\">确定</el-button>\n        </span>\n      </template>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport { getBanners, createBanner, updateBanner, deleteBanner } from '@/api/mall'\n\nexport default {\n  name: 'BannerList',\n  data() {\n    return {\n      loading: false,\n      banners: [],\n      searchForm: {\n        title: ''\n      },\n      pagination: {\n        current: 1,\n        size: 10,\n        total: 0\n      },\n      dialogVisible: false,\n      dialogTitle: '',\n      form: {\n        id: '',\n        title: '',\n        link_url: '',\n        sort_order: 0,\n        is_active: true\n      }\n    }\n  },\n  mounted() {\n    this.fetchBanners()\n  },\n  methods: {\n    fetchBanners() {\n      this.loading = true\n      const params = {\n        page: this.pagination.current,\n        page_size: this.pagination.size,\n        search: this.searchForm.title\n      }\n      getBanners(params)\n        .then(response => {\n          // 后端直接返回数组格式，不是 { results: [...], count: number } 格式\n          // 映射后端字段到前端字段\n          this.banners = response.data.map(item => ({\n            ...item,\n            link_url: item.link,  // 后端字段是link，前端使用link_url\n            sort_order: item.sort  // 后端字段是sort，前端使用sort_order\n          }))\n          this.pagination.total = response.data.length\n        })\n        .catch(error => {\n          this.$message.error('获取Banner列表失败: ' + error.message)\n        })\n        .finally(() => {\n          this.loading = false\n        })\n    },\n    handleAdd() {\n      this.dialogTitle = '添加Banner'\n      this.form = {\n        id: '',\n        title: '',\n        link_url: '',\n        sort_order: 0,\n        is_active: true\n      }\n      this.dialogVisible = true\n    },\n    handleEdit(row) {\n      this.dialogTitle = '编辑Banner'\n      this.form = { ...row }\n      this.dialogVisible = true\n    },\n    handleSubmit() {\n      if (!this.form.title) {\n        this.$message.error('请输入Banner名称')\n        return\n      }\n      if (!this.form.link_url) {\n        this.$message.error('请输入链接地址')\n        return\n      }\n      \n      // 准备提交数据，将前端字段映射回后端字段\n      const submitData = {\n        title: this.form.title,\n        link: this.form.link_url,  // 前端使用link_url，后端需要link\n        sort: this.form.sort_order,  // 前端使用sort_order，后端需要sort\n        is_active: this.form.is_active ? 1 : 0  // 前端使用布尔值，后端需要数字\n      }\n      \n      const request = this.form.id ? updateBanner(this.form.id, submitData) : createBanner(submitData)\n      request\n        .then(() => {\n          this.$message.success(this.form.id ? '更新Banner成功' : '添加Banner成功')\n          this.dialogVisible = false\n          this.fetchBanners()\n        })\n        .catch(error => {\n          this.$message.error((this.form.id ? '更新Banner' : '添加Banner') + '失败: ' + error.message)\n        })\n    },\n    handleDelete(id) {\n      this.$confirm('确定要删除这个Banner吗？', '警告', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      })\n        .then(() => {\n          deleteBanner(id)\n            .then(() => {\n              this.$message.success('删除Banner成功')\n              this.fetchBanners()\n            })\n            .catch(error => {\n              this.$message.error('删除Banner失败: ' + error.message)\n            })\n        })\n        .catch(() => {})\n    },\n    resetForm() {\n      this.searchForm = {\n        title: ''\n      }\n      this.fetchBanners()\n    },\n    handleSizeChange(size) {\n      this.pagination.size = size\n      this.fetchBanners()\n    },\n    handleCurrentChange(current) {\n      this.pagination.current = current\n      this.fetchBanners()\n    }\n  }\n}\n</script>\n\n<style scoped>\n.banner-management {\n  padding: 20px;\n}\n\n.card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.search-form {\n  margin-bottom: 20px;\n  padding: 10px;\n  background-color: #f5f7fa;\n  border-radius: 4px;\n}\n\n.pagination-container {\n  margin-top: 20px;\n  display: flex;\n  justify-content: flex-end;\n}\n\n\n\n.dialog-footer {\n  width: 100%;\n  display: flex;\n  justify-content: flex-end;\n}\n</style>"],"mappings":";;AAyFA,SAAAA,UAAA,EAAAC,YAAA,EAAAC,YAAA,EAAAC,YAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,OAAA;MACAC,OAAA;MACAC,UAAA;QACAC,KAAA;MACA;MACAC,UAAA;QACAC,OAAA;QACAC,IAAA;QACAC,KAAA;MACA;MACAC,aAAA;MACAC,WAAA;MACAC,IAAA;QACAC,EAAA;QACAR,KAAA;QACAS,QAAA;QACAC,UAAA;QACAC,SAAA;MACA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,YAAA;EACA;EACAC,OAAA;IACAD,aAAA;MACA,KAAAhB,OAAA;MACA,MAAAkB,MAAA;QACAC,IAAA,OAAAf,UAAA,CAAAC,OAAA;QACAe,SAAA,OAAAhB,UAAA,CAAAE,IAAA;QACAe,MAAA,OAAAnB,UAAA,CAAAC;MACA;MACAT,UAAA,CAAAwB,MAAA,EACAI,IAAA,CAAAC,QAAA;QACA;QACA;QACA,KAAAtB,OAAA,GAAAsB,QAAA,CAAAxB,IAAA,CAAAyB,GAAA,CAAAC,IAAA;UACA,GAAAA,IAAA;UACAb,QAAA,EAAAa,IAAA,CAAAC,IAAA;UAAA;UACAb,UAAA,EAAAY,IAAA,CAAAE,IAAA;QACA;QACA,KAAAvB,UAAA,CAAAG,KAAA,GAAAgB,QAAA,CAAAxB,IAAA,CAAA6B,MAAA;MACA,GACAC,KAAA,CAAAC,KAAA;QACA,KAAAC,QAAA,CAAAD,KAAA,oBAAAA,KAAA,CAAAE,OAAA;MACA,GACAC,OAAA;QACA,KAAAjC,OAAA;MACA;IACA;IACAkC,UAAA;MACA,KAAAzB,WAAA;MACA,KAAAC,IAAA;QACAC,EAAA;QACAR,KAAA;QACAS,QAAA;QACAC,UAAA;QACAC,SAAA;MACA;MACA,KAAAN,aAAA;IACA;IACA2B,WAAAC,GAAA;MACA,KAAA3B,WAAA;MACA,KAAAC,IAAA;QAAA,GAAA0B;MAAA;MACA,KAAA5B,aAAA;IACA;IACA6B,aAAA;MACA,UAAA3B,IAAA,CAAAP,KAAA;QACA,KAAA4B,QAAA,CAAAD,KAAA;QACA;MACA;MACA,UAAApB,IAAA,CAAAE,QAAA;QACA,KAAAmB,QAAA,CAAAD,KAAA;QACA;MACA;;MAEA;MACA,MAAAQ,UAAA;QACAnC,KAAA,OAAAO,IAAA,CAAAP,KAAA;QACAuB,IAAA,OAAAhB,IAAA,CAAAE,QAAA;QAAA;QACAe,IAAA,OAAAjB,IAAA,CAAAG,UAAA;QAAA;QACAC,SAAA,OAAAJ,IAAA,CAAAI,SAAA;MACA;MAEA,MAAAyB,OAAA,QAAA7B,IAAA,CAAAC,EAAA,GAAAf,YAAA,MAAAc,IAAA,CAAAC,EAAA,EAAA2B,UAAA,IAAA3C,YAAA,CAAA2C,UAAA;MACAC,OAAA,CACAjB,IAAA;QACA,KAAAS,QAAA,CAAAS,OAAA,MAAA9B,IAAA,CAAAC,EAAA;QACA,KAAAH,aAAA;QACA,KAAAQ,YAAA;MACA,GACAa,KAAA,CAAAC,KAAA;QACA,KAAAC,QAAA,CAAAD,KAAA,OAAApB,IAAA,CAAAC,EAAA,uCAAAmB,KAAA,CAAAE,OAAA;MACA;IACA;IACAS,aAAA9B,EAAA;MACA,KAAA+B,QAAA;QACAC,iBAAA;QACAC,gBAAA;QACAC,IAAA;MACA,GACAvB,IAAA;QACAzB,YAAA,CAAAc,EAAA,EACAW,IAAA;UACA,KAAAS,QAAA,CAAAS,OAAA;UACA,KAAAxB,YAAA;QACA,GACAa,KAAA,CAAAC,KAAA;UACA,KAAAC,QAAA,CAAAD,KAAA,kBAAAA,KAAA,CAAAE,OAAA;QACA;MACA,GACAH,KAAA;IACA;IACAiB,UAAA;MACA,KAAA5C,UAAA;QACAC,KAAA;MACA;MACA,KAAAa,YAAA;IACA;IACA+B,iBAAAzC,IAAA;MACA,KAAAF,UAAA,CAAAE,IAAA,GAAAA,IAAA;MACA,KAAAU,YAAA;IACA;IACAgC,oBAAA3C,OAAA;MACA,KAAAD,UAAA,CAAAC,OAAA,GAAAA,OAAA;MACA,KAAAW,YAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}