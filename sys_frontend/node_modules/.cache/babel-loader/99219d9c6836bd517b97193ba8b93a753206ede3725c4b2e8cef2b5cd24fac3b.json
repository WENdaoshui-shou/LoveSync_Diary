{"ast":null,"code":"import { getUserInfo } from '@/api/auth';\nexport default {\n  name: 'AdminLayout',\n  data() {\n    return {\n      userInfo: null\n    };\n  },\n  created() {\n    this.loadUserInfo();\n  },\n  methods: {\n    async loadUserInfo() {\n      try {\n        const response = await getUserInfo();\n\n        // 检查响应格式，适配不同的API响应格式\n        if (response && response.data) {\n          const responseData = response.data;\n\n          // 处理标准格式：{ success: true, data: {...} }\n          if (responseData.success === true && responseData.data) {\n            this.userInfo = responseData.data;\n          }\n          // 处理其他可能的格式\n          else if (responseData.id) {\n            this.userInfo = responseData;\n          } else if (responseData.code === 200 && responseData.data) {\n            this.userInfo = responseData.data;\n          } else {\n            // 静默处理无法识别的格式\n          }\n        } else {\n          // 静默处理空数据\n        }\n      } catch (error) {\n        console.error('获取用户信息失败:', error);\n        if (error.response && error.response.status === 401) {\n          this.$message.error('用户未认证，需要重新登录');\n          // 可以在这里添加重定向到登录页面的逻辑\n          // this.$router.push('/login')\n        } else {\n          this.$message.error('获取用户信息失败，请稍后重试');\n        }\n      }\n    },\n    handleCommand(command) {\n      if (command === 'logout') {\n        this.logout();\n      }\n    },\n    logout() {\n      this.$confirm('确定要退出登录吗？', '确认退出', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        localStorage.removeItem('admin_token');\n        this.$router.replace('/login');\n        this.$message.success('退出登录成功');\n      }).catch(() => {\n        // 用户取消\n      });\n    }\n  }\n};","map":{"version":3,"names":["getUserInfo","name","data","userInfo","created","loadUserInfo","methods","response","responseData","success","id","code","error","console","status","$message","handleCommand","command","logout","$confirm","confirmButtonText","cancelButtonText","type","then","localStorage","removeItem","$router","replace","catch"],"sources":["src/views/Layout.vue"],"sourcesContent":["<template>\n  <div class=\"admin-layout\">\n    <!-- 背景装饰元素 -->\n    <div class=\"bg-decoration\">\n      <div class=\"bg-circle bg-circle-1\"></div>\n      <div class=\"bg-circle bg-circle-2\"></div>\n      <div class=\"bg-circle bg-circle-3\"></div>\n    </div>\n\n    <el-container class=\"layout-container\">\n      <!-- 头部 -->\n      <el-header class=\"layout-header\">\n        <div class=\"header-content\">\n          <div class=\"logo\">\n            <a href=\"/\" class=\"flex items-center space-x-2\">\n              <div\n                class=\"w-10 h-10 rounded-full bg-gradient-love flex items-center justify-center text-white shadow-md\">\n                <i class=\"el-icon-love text-xl\"></i>\n              </div>\n              <span class=\"text-xl font-bold text-neutral-800 tracking-tight\">LoveSync 管理后台</span>\n            </a>\n          </div>\n          <div class=\"header-right\">\n            <el-dropdown @command=\"handleCommand\">\n              <span class=\"el-dropdown-link flex items-center space-x-2 hover-scale\">\n                <div class=\"w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center\">\n                  <i class=\"el-icon-user text-primary\"></i>\n                </div>\n                <span>{{ userInfo?.name || '管理员' }}</span>\n                <i class=\"el-icon-arrow-down el-icon--right\"></i>\n              </span>\n              <el-dropdown-menu slot=\"dropdown\">\n                <el-dropdown-item command=\"logout\" class=\"flex items-center space-x-2\">\n                  <i class=\"el-icon-switch-button text-neutral-500\"></i>\n                  <span>退出登录</span>\n                </el-dropdown-item>\n              </el-dropdown-menu>\n            </el-dropdown>\n          </div>\n        </div>\n      </el-header>\n\n      <el-container>\n        <!-- 侧边栏 -->\n        <el-aside width=\"220px\" class=\"layout-aside\">\n          <el-menu :default-active=\"$route.path\" class=\"layout-menu\" router background-color=\"rgba(255, 255, 255, 0.95)\"\n            text-color=\"#757575\" active-text-color=\"#FF6B8B\" :unique-opened=\"true\" :collapse-transition=\"true\">\n            <el-menu-item index=\"/\" class=\"menu-item\">\n              <i class=\"el-icon-s-home menu-icon\"></i>\n              <span slot=\"title\">首页</span>\n            </el-menu-item>\n\n            <el-menu-item index=\"/users\" class=\"menu-item\">\n              <i class=\"el-icon-user menu-icon\"></i>\n              <span slot=\"title\">用户管理</span>\n            </el-menu-item>\n\n            <el-menu-item index=\"/moments\" class=\"menu-item\">\n              <i class=\"el-icon-news menu-icon\"></i>\n              <span slot=\"title\">动态管理</span>\n            </el-menu-item>\n\n            <el-submenu index=\"/community\" class=\"menu-item\">\n              <template slot=\"title\">\n                <i class=\"el-icon-s-grid menu-icon\"></i>\n                <span>社区管理</span>\n              </template>\n              <el-menu-item index=\"/community/events\" class=\"sub-menu-item\">\n                <i class=\"el-icon-date sub-menu-icon\"></i>\n                <span slot=\"title\">社区活动</span>\n              </el-menu-item>\n              <el-menu-item index=\"/community/articles\" class=\"sub-menu-item\">\n                <i class=\"el-icon-document sub-menu-icon\"></i>\n                <span slot=\"title\">文章专栏</span>\n              </el-menu-item>\n              <el-menu-item index=\"/community/topics\" class=\"sub-menu-item\">\n                <i class=\"el-icon-top sub-menu-icon\"></i>\n                <span slot=\"title\">热门话题</span>\n              </el-menu-item>\n              <el-menu-item index=\"/community/reports\" class=\"sub-menu-item\">\n                <i class=\"el-icon-warning-outline sub-menu-icon\"></i>\n                <span slot=\"title\">举报管理</span>\n              </el-menu-item>\n            </el-submenu>\n\n            <el-submenu index=\"/couple\" class=\"menu-item\">\n              <template slot=\"title\">\n                <i class=\"el-icon-connection menu-icon\"></i>\n                <span>情侣管理</span>\n              </template>\n              <el-menu-item index=\"/couple/recommended\" class=\"sub-menu-item\">\n                <i class=\"el-icon-sunny sub-menu-icon\"></i>\n                <span slot=\"title\">推荐情侣管理</span>\n              </el-menu-item>\n              <el-menu-item index=\"/couple/places\" class=\"sub-menu-item\">\n                <i class=\"el-icon-s-flag sub-menu-icon\"></i>\n                <span slot=\"title\">地点管理</span>\n              </el-menu-item>\n              <el-menu-item index=\"/couple/tests\" class=\"sub-menu-item\">\n                <i class=\"el-icon-question sub-menu-icon\"></i>\n                <span slot=\"title\">爱情测试管理</span>\n              </el-menu-item>\n              <el-menu-item index=\"/couple/games\" class=\"sub-menu-item\">\n                <i class=\"el-icon-s-grid sub-menu-icon\"></i>\n                <span slot=\"title\">情侣游戏管理</span>\n              </el-menu-item>\n            </el-submenu>\n\n            <el-submenu index=\"/mall\" class=\"menu-item\">\n              <template slot=\"title\">\n                <i class=\"el-icon-shopping-cart menu-icon\"></i>\n                <span>商城管理</span>\n              </template>\n              <!-- 商品管理 -->\n              <el-menu-item index=\"/mall/products\" class=\"sub-menu-item\">\n                <i class=\"el-icon-goods sub-menu-icon\"></i>\n                <span slot=\"title\">商品管理</span>\n              </el-menu-item>\n              <!-- 分类管理 -->\n              <el-menu-item index=\"/mall/categories\" class=\"sub-menu-item\">\n                <i class=\"el-icon-menu sub-menu-icon\"></i>\n                <span slot=\"title\">分类管理</span>\n              </el-menu-item>\n              <!-- 订单管理 -->\n              <el-menu-item index=\"/mall/orders\" class=\"sub-menu-item\">\n                <i class=\"el-icon-document sub-menu-icon\"></i>\n                <span slot=\"title\">订单管理</span>\n              </el-menu-item>\n              <!-- 营销管理 -->\n              <el-submenu index=\"/mall/marketing\" class=\"sub-menu-item\">\n                <template slot=\"title\">\n                  <i class=\"el-icon-s-marketing sub-menu-icon\"></i>\n                  <span>营销管理</span>\n                </template>\n                <el-menu-item index=\"/mall/marketing/flash-sale\" class=\"deep-sub-menu-item\">\n                  <i class=\"el-icon-lightning deep-sub-menu-icon\"></i>\n                  <span slot=\"title\">闪购管理</span>\n                </el-menu-item>\n                <el-menu-item index=\"/mall/marketing/coupon\" class=\"deep-sub-menu-item\">\n                  <i class=\"el-icon-ticket deep-sub-menu-icon\"></i>\n                  <span slot=\"title\">优惠券管理</span>\n                </el-menu-item>\n              </el-submenu>\n              <!-- 内容管理 -->\n              <el-menu-item index=\"/mall/content\" class=\"sub-menu-item\">\n                <i class=\"el-icon-picture sub-menu-icon\"></i>\n                <span slot=\"title\">Banner管理</span>\n              </el-menu-item>\n              <!-- 用户地址管理 -->\n              <el-menu-item index=\"/mall/users\" class=\"sub-menu-item\">\n                <i class=\"el-icon-user sub-menu-icon\"></i>\n                <span slot=\"title\">用户地址管理</span>\n              </el-menu-item>\n            </el-submenu>\n\n          </el-menu>\n        </el-aside>\n\n        <!-- 主内容区 -->\n        <el-main class=\"layout-main\">\n          <router-view />\n        </el-main>\n      </el-container>\n    </el-container>\n  </div>\n</template>\n\n<script>\nimport { getUserInfo } from '@/api/auth'\n\nexport default {\n  name: 'AdminLayout',\n  data() {\n    return {\n      userInfo: null\n    }\n  },\n  created() {\n    this.loadUserInfo()\n  },\n  methods: {\n    async loadUserInfo() {\n      try {\n        const response = await getUserInfo()\n\n        // 检查响应格式，适配不同的API响应格式\n        if (response && response.data) {\n          const responseData = response.data\n\n          // 处理标准格式：{ success: true, data: {...} }\n          if (responseData.success === true && responseData.data) {\n            this.userInfo = responseData.data\n          }\n          // 处理其他可能的格式\n          else if (responseData.id) {\n            this.userInfo = responseData\n          }\n          else if (responseData.code === 200 && responseData.data) {\n            this.userInfo = responseData.data\n          }\n          else {\n            // 静默处理无法识别的格式\n          }\n        } else {\n          // 静默处理空数据\n        }\n      } catch (error) {\n        console.error('获取用户信息失败:', error)\n        if (error.response && error.response.status === 401) {\n          this.$message.error('用户未认证，需要重新登录')\n          // 可以在这里添加重定向到登录页面的逻辑\n          // this.$router.push('/login')\n        } else {\n          this.$message.error('获取用户信息失败，请稍后重试')\n        }\n      }\n    },\n\n    handleCommand(command) {\n      if (command === 'logout') {\n        this.logout()\n      }\n    },\n\n    logout() {\n      this.$confirm('确定要退出登录吗？', '确认退出', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        localStorage.removeItem('admin_token')\n        this.$router.replace('/login')\n        this.$message.success('退出登录成功')\n      }).catch(() => {\n        // 用户取消\n      })\n    }\n  }\n}\n</script>\n\n<style scoped>\n.layout-container {\n  height: 100vh;\n}\n\n.layout-header {\n  background-color: #fff;\n  box-shadow: 0 2px 4px rgba(0, 21, 41, 0.08);\n  padding: 0 20px;\n}\n\n.header-content {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  height: 60px;\n}\n\n.logo h2 {\n  margin: 0;\n  color: #303133;\n  font-size: 20px;\n}\n\n.header-right {\n  display: flex;\n  align-items: center;\n}\n\n.el-dropdown-link {\n  cursor: pointer;\n  color: #409EFF;\n}\n\n.layout-aside {\n  background-color: #304156;\n  border-right: 1px solid #e6e6e6;\n}\n\n.layout-menu {\n  border-right: none;\n  height: calc(100vh - 60px);\n}\n\n.layout-main {\n  background-color: #f5f5f5;\n  padding: 20px;\n}\n</style>"],"mappings":"AAwKA,SAAAA,WAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,QAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,YAAA;EACA;EACAC,OAAA;IACA,MAAAD,aAAA;MACA;QACA,MAAAE,QAAA,SAAAP,WAAA;;QAEA;QACA,IAAAO,QAAA,IAAAA,QAAA,CAAAL,IAAA;UACA,MAAAM,YAAA,GAAAD,QAAA,CAAAL,IAAA;;UAEA;UACA,IAAAM,YAAA,CAAAC,OAAA,aAAAD,YAAA,CAAAN,IAAA;YACA,KAAAC,QAAA,GAAAK,YAAA,CAAAN,IAAA;UACA;UACA;UAAA,KACA,IAAAM,YAAA,CAAAE,EAAA;YACA,KAAAP,QAAA,GAAAK,YAAA;UACA,OACA,IAAAA,YAAA,CAAAG,IAAA,YAAAH,YAAA,CAAAN,IAAA;YACA,KAAAC,QAAA,GAAAK,YAAA,CAAAN,IAAA;UACA,OACA;YACA;UAAA;QAEA;UACA;QAAA;MAEA,SAAAU,KAAA;QACAC,OAAA,CAAAD,KAAA,cAAAA,KAAA;QACA,IAAAA,KAAA,CAAAL,QAAA,IAAAK,KAAA,CAAAL,QAAA,CAAAO,MAAA;UACA,KAAAC,QAAA,CAAAH,KAAA;UACA;UACA;QACA;UACA,KAAAG,QAAA,CAAAH,KAAA;QACA;MACA;IACA;IAEAI,cAAAC,OAAA;MACA,IAAAA,OAAA;QACA,KAAAC,MAAA;MACA;IACA;IAEAA,OAAA;MACA,KAAAC,QAAA;QACAC,iBAAA;QACAC,gBAAA;QACAC,IAAA;MACA,GAAAC,IAAA;QACAC,YAAA,CAAAC,UAAA;QACA,KAAAC,OAAA,CAAAC,OAAA;QACA,KAAAZ,QAAA,CAAAN,OAAA;MACA,GAAAmB,KAAA;QACA;MAAA,CACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}