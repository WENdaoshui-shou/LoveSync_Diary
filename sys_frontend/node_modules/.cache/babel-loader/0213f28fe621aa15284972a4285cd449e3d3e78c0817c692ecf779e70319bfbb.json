{"ast":null,"code":"export default {\n  name: 'CommunityEvents',\n  data() {\n    return {\n      loading: false,\n      eventList: [],\n      total: 0,\n      currentPage: 1,\n      pageSize: 10,\n      filterForm: {\n        search: '',\n        status: '',\n        is_pinned: '',\n        date_range: ''\n      },\n      statistics: {\n        totalEvents: 5,\n        activeEvents: 2,\n        upcomingEvents: 1,\n        totalParticipants: 1250\n      },\n      detailDialogVisible: false,\n      currentEvent: null\n    };\n  },\n  created() {\n    this.loadData();\n    this.loadStatistics();\n  },\n  methods: {\n    async loadData() {\n      this.loading = true;\n      try {\n        // 模拟数据\n        this.eventList = [{\n          id: 1,\n          title: '情人节特别活动',\n          description: '情侣互动游戏，赢取精美礼品，分享甜蜜瞬间',\n          status: 'active',\n          is_pinned: true,\n          start_date: '2024-02-14T10:00:00Z',\n          end_date: '2024-02-14T22:00:00Z',\n          location: '线上活动',\n          participant_count: 450,\n          prize_info: '情侣套餐券、玫瑰花束、巧克力礼盒',\n          created_at: '2024-02-10T10:00:00Z'\n        }, {\n          id: 2,\n          title: '春季摄影大赛',\n          description: '展示你眼中的春天美景，分享生活中的美好瞬间',\n          status: 'upcoming',\n          is_pinned: false,\n          start_date: '2024-03-01T00:00:00Z',\n          end_date: '2024-03-31T23:59:59Z',\n          location: '全国范围',\n          participant_count: 0,\n          prize_info: '专业相机、摄影书籍、精美相框',\n          created_at: '2024-02-08T14:30:00Z'\n        }, {\n          id: 3,\n          title: '美食分享活动',\n          description: '分享你制作或品尝的美食，交流烹饪心得',\n          status: 'ended',\n          is_pinned: false,\n          start_date: '2024-01-15T00:00:00Z',\n          end_date: '2024-01-31T23:59:59Z',\n          location: '线上分享',\n          participant_count: 320,\n          prize_info: '厨具套装、美食书籍、餐厅代金券',\n          created_at: '2024-01-10T09:00:00Z'\n        }];\n        this.total = this.eventList.length;\n      } catch (error) {\n        console.error('加载活动数据失败:', error);\n        this.$message.error('加载数据失败');\n      } finally {\n        this.loading = false;\n      }\n    },\n    async loadStatistics() {\n      try {\n        // 这里可以添加API调用来加载统计数据\n        this.statistics = {\n          totalEvents: 5,\n          activeEvents: 2,\n          upcomingEvents: 1,\n          totalParticipants: 1250\n        };\n      } catch (error) {\n        console.error('加载统计数据失败:', error);\n      }\n    },\n    handleSearch() {\n      this.currentPage = 1;\n      this.loadData();\n    },\n    resetFilter() {\n      this.filterForm = {\n        search: '',\n        status: '',\n        is_pinned: '',\n        date_range: ''\n      };\n      this.currentPage = 1;\n      this.loadData();\n    },\n    handleSizeChange(val) {\n      this.pageSize = val;\n      this.loadData();\n    },\n    handleCurrentChange(val) {\n      this.currentPage = val;\n      this.loadData();\n    },\n    createEvent() {\n      this.$message.info('创建活动功能开发中...');\n    },\n    viewEvent(event) {\n      this.currentEvent = event;\n      this.detailDialogVisible = true;\n    },\n    editEvent(event) {\n      this.$message.info(`编辑活动: ${event.title}`);\n    },\n    async togglePin(event) {\n      try {\n        const action = event.is_pinned ? '取消置顶' : '置顶';\n        await this.$confirm(`确定要${action}活动 \"${event.title}\" 吗？`, '确认', {\n          confirmButtonText: '确定',\n          cancelButtonText: '取消',\n          type: 'warning'\n        });\n\n        // 这里可以添加API调用来切换置顶状态\n        event.is_pinned = !event.is_pinned;\n        this.$message.success(`${action}成功`);\n      } catch (error) {\n        // 用户取消操作\n      }\n    },\n    async toggleStatus(event) {\n      try {\n        const action = this.getStatusActionText(event.status);\n        await this.$confirm(`确定要${action}活动 \"${event.title}\" 吗？`, '确认', {\n          confirmButtonText: '确定',\n          cancelButtonText: '取消',\n          type: 'warning'\n        });\n\n        // 这里可以添加API调用来切换状态\n        const statusTransitions = {\n          'active': 'ended',\n          'upcoming': 'active',\n          'ended': 'upcoming'\n        };\n        event.status = statusTransitions[event.status] || 'upcoming';\n        this.$message.success(`${action}成功`);\n      } catch (error) {\n        // 用户取消操作\n      }\n    },\n    async deleteEvent(event) {\n      try {\n        await this.$confirm(`确定要删除活动 \"${event.title}\" 吗？此操作不可恢复。`, '确认删除', {\n          confirmButtonText: '确定',\n          cancelButtonText: '取消',\n          type: 'warning'\n        });\n\n        // 这里可以添加API调用来删除活动\n        this.$message.success('活动删除成功');\n        this.loadData();\n      } catch (error) {\n        // 用户取消操作\n      }\n    },\n    refreshData() {\n      this.loadData();\n      this.loadStatistics();\n      this.$message.success('数据已刷新');\n    },\n    // 辅助方法\n    getStatusType(status) {\n      const types = {\n        'active': 'success',\n        'upcoming': 'info',\n        'ended': 'danger'\n      };\n      return types[status] || 'info';\n    },\n    getStatusText(status) {\n      const texts = {\n        'active': '进行中',\n        'upcoming': '即将开始',\n        'ended': '已结束'\n      };\n      return texts[status] || status;\n    },\n    getStatusButtonType(status) {\n      const types = {\n        'active': 'warning',\n        'upcoming': 'success',\n        'ended': 'primary'\n      };\n      return types[status] || 'primary';\n    },\n    getStatusActionText(status) {\n      const actions = {\n        'active': '结束活动',\n        'upcoming': '开始活动',\n        'ended': '重新激活'\n      };\n      return actions[status] || '操作';\n    },\n    formatDate(dateString) {\n      const date = new Date(dateString);\n      return date.toLocaleString('zh-CN', {\n        year: 'numeric',\n        month: '2-digit',\n        day: '2-digit',\n        hour: '2-digit',\n        minute: '2-digit'\n      });\n    },\n    truncateText(text, maxLength) {\n      if (!text) return '';\n      return text.length > maxLength ? text.substring(0, maxLength) + '...' : text;\n    }\n  }\n};","map":{"version":3,"names":["name","data","loading","eventList","total","currentPage","pageSize","filterForm","search","status","is_pinned","date_range","statistics","totalEvents","activeEvents","upcomingEvents","totalParticipants","detailDialogVisible","currentEvent","created","loadData","loadStatistics","methods","id","title","description","start_date","end_date","location","participant_count","prize_info","created_at","length","error","console","$message","handleSearch","resetFilter","handleSizeChange","val","handleCurrentChange","createEvent","info","viewEvent","event","editEvent","togglePin","action","$confirm","confirmButtonText","cancelButtonText","type","success","toggleStatus","getStatusActionText","statusTransitions","deleteEvent","refreshData","getStatusType","types","getStatusText","texts","getStatusButtonType","actions","formatDate","dateString","date","Date","toLocaleString","year","month","day","hour","minute","truncateText","text","maxLength","substring"],"sources":["src/views/community/CommunityEvents.vue"],"sourcesContent":["<template>\n  <div class=\"community-events\">\n    <h1>社区活动管理</h1>\n    <p>管理社区活动，包括创建、编辑、状态控制等</p>\n    \n    <!-- 活动统计 -->\n    <div class=\"stats-container\">\n      <el-row :gutter=\"20\">\n        <el-col :span=\"6\">\n          <el-card class=\"stat-card\">\n            <div class=\"stat-content\">\n              <div class=\"stat-number\">{{ stats.totalEvents || 0 }}</div>\n              <div class=\"stat-label\">总活动数</div>\n            </div>\n          </el-card>\n        </el-col>\n        <el-col :span=\"6\">\n          <el-card class=\"stat-card\">\n            <div class=\"stat-content\">\n              <div class=\"stat-number text-success\">{{ stats.activeEvents || 0 }}</div>\n              <div class=\"stat-label\">进行中</div>\n            </div>\n          </el-card>\n        </el-col>\n        <el-col :span=\"6\">\n          <el-card class=\"stat-card\">\n            <div class=\"stat-content\">\n              <div class=\"stat-number text-info\">{{ stats.upcomingEvents || 0 }}</div>\n              <div class=\"stat-label\">即将开始</div>\n            </div>\n          </el-card>\n        </el-col>\n        <el-col :span=\"6\">\n          <el-card class=\"stat-card\">\n            <div class=\"stat-content\">\n              <div class=\"stat-number text-warning\">{{ stats.totalParticipants || 0 }}</div>\n              <div class=\"stat-label\">总参与人数</div>\n            </div>\n          </el-card>\n        </el-col>\n      </el-row>\n    </div>\n\n    <!-- 操作栏 -->\n    <div class=\"action-bar\">\n      <el-button type=\"primary\" @click=\"createEvent\">\n        <i class=\"el-icon-plus\"></i> 创建活动\n      </el-button>\n      <el-button @click=\"refreshData\">\n        <i class=\"el-icon-refresh\"></i> 刷新\n      </el-button>\n    </div>\n\n    <!-- 筛选和搜索 -->\n    <el-card class=\"filter-card\">\n      <el-form :inline=\"true\" :model=\"filterForm\" class=\"filter-form\">\n        <el-form-item label=\"搜索\">\n          <el-input \n            v-model=\"filterForm.search\" \n            placeholder=\"搜索活动标题或描述\" \n            clearable \n            @clear=\"handleSearch\"\n            @keyup.enter=\"handleSearch\"\n            style=\"width: 250px\"\n          >\n            <el-button slot=\"append\" icon=\"el-icon-search\" @click=\"handleSearch\"></el-button>\n          </el-input>\n        </el-form-item>\n\n        <el-form-item label=\"状态\">\n          <el-select v-model=\"filterForm.status\" placeholder=\"全部状态\" clearable @change=\"handleSearch\">\n            <el-option label=\"全部\" value=\"\"></el-option>\n            <el-option label=\"进行中\" value=\"active\"></el-option>\n            <el-option label=\"即将开始\" value=\"upcoming\"></el-option>\n            <el-option label=\"已结束\" value=\"ended\"></el-option>\n          </el-select>\n        </el-form-item>\n\n        <el-form-item label=\"置顶\">\n          <el-select v-model=\"filterForm.is_pinned\" placeholder=\"全部\" clearable @change=\"handleSearch\">\n            <el-option label=\"全部\" value=\"\"></el-option>\n            <el-option label=\"置顶\" value=\"true\"></el-option>\n            <el-option label=\"未置顶\" value=\"false\"></el-option>\n          </el-select>\n        </el-form-item>\n\n        <el-form-item label=\"时间范围\">\n          <el-select v-model=\"filterForm.date_range\" placeholder=\"全部时间\" clearable @change=\"handleSearch\">\n            <el-option label=\"全部\" value=\"\"></el-option>\n            <el-option label=\"今天\" value=\"today\"></el-option>\n            <el-option label=\"本周\" value=\"week\"></el-option>\n            <el-option label=\"本月\" value=\"month\"></el-option>\n          </el-select>\n        </el-form-item>\n\n        <el-form-item>\n          <el-button type=\"primary\" @click=\"handleSearch\">搜索</el-button>\n          <el-button @click=\"resetFilter\">重置</el-button>\n        </el-form-item>\n      </el-form>\n    </el-card>\n\n    <!-- 活动列表 -->\n    <el-card class=\"list-card\">\n      <div slot=\"header\" class=\"card-header\">\n        <span>活动列表</span>\n      </div>\n\n      <el-table \n        :data=\"eventList\" \n        v-loading=\"loading\" \n        border \n        style=\"width: 100%\"\n      >\n        <el-table-column prop=\"id\" label=\"ID\" width=\"80\" align=\"center\"></el-table-column>\n        \n        <el-table-column label=\"活动信息\" min-width=\"300\">\n          <template slot-scope=\"scope\">\n            <div class=\"event-info\">\n              <div class=\"event-title\">{{ scope.row.title }}</div>\n              <div class=\"event-description\">{{ scope.row.description }}</div>\n              <div class=\"event-meta\">\n                <el-tag :type=\"getStatusType(scope.row.status)\" size=\"mini\">\n                  {{ getStatusText(scope.row.status) }}\n                </el-tag>\n                <el-tag v-if=\"scope.row.is_pinned\" type=\"warning\" size=\"mini\">置顶</el-tag>\n                <span class=\"event-location\" v-if=\"scope.row.location\">\n                  <i class=\"el-icon-location\"></i> {{ scope.row.location }}\n                </span>\n              </div>\n            </div>\n          </template>\n        </el-table-column>\n        \n        <el-table-column label=\"时间\" width=\"200\" align=\"center\">\n          <template slot-scope=\"scope\">\n            <div class=\"event-time\">\n              <div v-if=\"scope.row.start_date\">开始: {{ formatDate(scope.row.start_date) }}</div>\n              <div v-if=\"scope.row.end_date\">结束: {{ formatDate(scope.row.end_date) }}</div>\n              <div v-if=\"!scope.row.start_date && !scope.row.end_date\">无时间限制</div>\n            </div>\n          </template>\n        </el-table-column>\n        \n        <el-table-column label=\"参与人数\" width=\"100\" align=\"center\">\n          <template slot-scope=\"scope\">\n            <div class=\"participant-count\">\n              <span class=\"count\">{{ scope.row.participant_count }}</span>\n              <span class=\"unit\">人参与</span>\n            </div>\n          </template>\n        </el-table-column>\n        \n        <el-table-column label=\"奖品信息\" width=\"150\" align=\"center\">\n          <template slot-scope=\"scope\">\n            <div class=\"prize-info\" v-if=\"scope.row.prize_info\">\n              <el-tooltip :content=\"scope.row.prize_info\" placement=\"top\">\n                <span class=\"prize-text\">{{ truncateText(scope.row.prize_info, 20) }}</span>\n              </el-tooltip>\n            </div>\n            <div v-else class=\"no-prize\">无奖品</div>\n          </template>\n        </el-table-column>\n        \n        <el-table-column label=\"创建时间\" width=\"160\" align=\"center\">\n          <template slot-scope=\"scope\">\n            {{ formatDate(scope.row.created_at) }}\n          </template>\n        </el-table-column>\n        \n        <el-table-column label=\"操作\" width=\"200\" align=\"center\" fixed=\"right\">\n          <template slot-scope=\"scope\">\n            <el-button type=\"text\" size=\"mini\" @click=\"viewEvent(scope.row)\">详情</el-button>\n            <el-button type=\"text\" size=\"mini\" @click=\"editEvent(scope.row)\">编辑</el-button>\n            <el-button \n              type=\"text\" \n              size=\"mini\" \n              @click=\"togglePin(scope.row)\"\n            >\n              {{ scope.row.is_pinned ? '取消置顶' : '置顶' }}\n            </el-button>\n            <el-button \n              :type=\"getStatusButtonType(scope.row.status)\" \n              size=\"mini\" \n              @click=\"toggleStatus(scope.row)\"\n            >\n              {{ getStatusActionText(scope.row.status) }}\n            </el-button>\n            <el-button type=\"text\" size=\"mini\" @click=\"deleteEvent(scope.row)\">删除</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n\n      <!-- 分页 -->\n      <div class=\"pagination-container\">\n        <el-pagination \n          @size-change=\"handleSizeChange\" \n          @current-change=\"handleCurrentChange\" \n          :current-page=\"currentPage\"\n          :page-sizes=\"[10, 20, 50, 100]\" \n          :page-size=\"pageSize\" \n          layout=\"total, sizes, prev, pager, next, jumper\"\n          :total=\"total\"\n        ></el-pagination>\n      </div>\n    </el-card>\n\n    <!-- 活动详情对话框 -->\n    <el-dialog \n      title=\"活动详情\" \n      :visible.sync=\"detailDialogVisible\" \n      width=\"800px\"\n    >\n      <div v-if=\"currentEvent\" class=\"event-detail\">\n        <el-descriptions :column=\"2\" border>\n          <el-descriptions-item label=\"活动ID\">{{ currentEvent.id }}</el-descriptions-item>\n          <el-descriptions-item label=\"状态\">\n            <el-tag :type=\"getStatusType(currentEvent.status)\" size=\"small\">\n              {{ getStatusText(currentEvent.status) }}\n            </el-tag>\n          </el-descriptions-item>\n          <el-descriptions-item label=\"置顶\">\n            <el-tag v-if=\"currentEvent.is_pinned\" type=\"warning\" size=\"small\">置顶</el-tag>\n            <span v-else>否</span>\n          </el-descriptions-item>\n          <el-descriptions-item label=\"参与人数\">{{ currentEvent.participant_count }} 人</el-descriptions-item>\n          <el-descriptions-item label=\"开始时间\" v-if=\"currentEvent.start_date\">\n            {{ formatDate(currentEvent.start_date) }}\n          </el-descriptions-item>\n          <el-descriptions-item label=\"结束时间\" v-if=\"currentEvent.end_date\">\n            {{ formatDate(currentEvent.end_date) }}\n          </el-descriptions-item>\n          <el-descriptions-item label=\"活动地点\" v-if=\"currentEvent.location\">\n            {{ currentEvent.location }}\n          </el-descriptions-item>\n          <el-descriptions-item label=\"创建时间\">{{ formatDate(currentEvent.created_at) }}</el-descriptions-item>\n        </el-descriptions>\n\n        <div class=\"detail-section\">\n          <h4>活动标题</h4>\n          <p>{{ currentEvent.title }}</p>\n        </div>\n\n        <div class=\"detail-section\">\n          <h4>活动描述</h4>\n          <p>{{ currentEvent.description }}</p>\n        </div>\n\n        <div class=\"detail-section\" v-if=\"currentEvent.prize_info\">\n          <h4>奖品信息</h4>\n          <p>{{ currentEvent.prize_info }}</p>\n        </div>\n\n        <div class=\"detail-section\" v-if=\"currentEvent.image\">\n          <h4>活动图片</h4>\n          <img :src=\"currentEvent.image\" alt=\"活动图片\" class=\"event-image\">\n        </div>\n      </div>\n\n      <div slot=\"footer\" class=\"dialog-footer\">\n        <el-button @click=\"detailDialogVisible = false\">关闭</el-button>\n        <el-button \n          v-if=\"currentEvent\" \n          :type=\"currentEvent.is_pinned ? 'warning' : 'primary'\" \n          @click=\"togglePin(currentEvent)\"\n        >\n          {{ currentEvent.is_pinned ? '取消置顶' : '置顶' }}\n        </el-button>\n        <el-button \n          v-if=\"currentEvent\" \n          :type=\"getStatusButtonType(currentEvent.status)\" \n          @click=\"toggleStatus(currentEvent)\"\n        >\n          {{ getStatusActionText(currentEvent.status) }}\n        </el-button>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'CommunityEvents',\n  data() {\n    return {\n      loading: false,\n      eventList: [],\n      total: 0,\n      currentPage: 1,\n      pageSize: 10,\n      filterForm: {\n        search: '',\n        status: '',\n        is_pinned: '',\n        date_range: ''\n      },\n      statistics: {\n        totalEvents: 5,\n        activeEvents: 2,\n        upcomingEvents: 1,\n        totalParticipants: 1250\n      },\n      detailDialogVisible: false,\n      currentEvent: null\n    }\n  },\n  created() {\n    this.loadData()\n    this.loadStatistics()\n  },\n  methods: {\n    async loadData() {\n      this.loading = true\n      try {\n        // 模拟数据\n        this.eventList = [\n          {\n            id: 1,\n            title: '情人节特别活动',\n            description: '情侣互动游戏，赢取精美礼品，分享甜蜜瞬间',\n            status: 'active',\n            is_pinned: true,\n            start_date: '2024-02-14T10:00:00Z',\n            end_date: '2024-02-14T22:00:00Z',\n            location: '线上活动',\n            participant_count: 450,\n            prize_info: '情侣套餐券、玫瑰花束、巧克力礼盒',\n            created_at: '2024-02-10T10:00:00Z'\n          },\n          {\n            id: 2,\n            title: '春季摄影大赛',\n            description: '展示你眼中的春天美景，分享生活中的美好瞬间',\n            status: 'upcoming',\n            is_pinned: false,\n            start_date: '2024-03-01T00:00:00Z',\n            end_date: '2024-03-31T23:59:59Z',\n            location: '全国范围',\n            participant_count: 0,\n            prize_info: '专业相机、摄影书籍、精美相框',\n            created_at: '2024-02-08T14:30:00Z'\n          },\n          {\n            id: 3,\n            title: '美食分享活动',\n            description: '分享你制作或品尝的美食，交流烹饪心得',\n            status: 'ended',\n            is_pinned: false,\n            start_date: '2024-01-15T00:00:00Z',\n            end_date: '2024-01-31T23:59:59Z',\n            location: '线上分享',\n            participant_count: 320,\n            prize_info: '厨具套装、美食书籍、餐厅代金券',\n            created_at: '2024-01-10T09:00:00Z'\n          }\n        ]\n        this.total = this.eventList.length\n      } catch (error) {\n        console.error('加载活动数据失败:', error)\n        this.$message.error('加载数据失败')\n      } finally {\n        this.loading = false\n      }\n    },\n\n    async loadStatistics() {\n      try {\n        // 这里可以添加API调用来加载统计数据\n        this.statistics = {\n          totalEvents: 5,\n          activeEvents: 2,\n          upcomingEvents: 1,\n          totalParticipants: 1250\n        }\n      } catch (error) {\n        console.error('加载统计数据失败:', error)\n      }\n    },\n\n    handleSearch() {\n      this.currentPage = 1\n      this.loadData()\n    },\n\n    resetFilter() {\n      this.filterForm = {\n        search: '',\n        status: '',\n        is_pinned: '',\n        date_range: ''\n      }\n      this.currentPage = 1\n      this.loadData()\n    },\n\n    handleSizeChange(val) {\n      this.pageSize = val\n      this.loadData()\n    },\n\n    handleCurrentChange(val) {\n      this.currentPage = val\n      this.loadData()\n    },\n\n    createEvent() {\n      this.$message.info('创建活动功能开发中...')\n    },\n\n    viewEvent(event) {\n      this.currentEvent = event\n      this.detailDialogVisible = true\n    },\n\n    editEvent(event) {\n      this.$message.info(`编辑活动: ${event.title}`)\n    },\n\n    async togglePin(event) {\n      try {\n        const action = event.is_pinned ? '取消置顶' : '置顶'\n        await this.$confirm(`确定要${action}活动 \"${event.title}\" 吗？`, '确认', {\n          confirmButtonText: '确定',\n          cancelButtonText: '取消',\n          type: 'warning'\n        })\n        \n        // 这里可以添加API调用来切换置顶状态\n        event.is_pinned = !event.is_pinned\n        this.$message.success(`${action}成功`)\n      } catch (error) {\n        // 用户取消操作\n      }\n    },\n\n    async toggleStatus(event) {\n      try {\n        const action = this.getStatusActionText(event.status)\n        await this.$confirm(`确定要${action}活动 \"${event.title}\" 吗？`, '确认', {\n          confirmButtonText: '确定',\n          cancelButtonText: '取消',\n          type: 'warning'\n        })\n        \n        // 这里可以添加API调用来切换状态\n        const statusTransitions = {\n          'active': 'ended',\n          'upcoming': 'active',\n          'ended': 'upcoming'\n        }\n        event.status = statusTransitions[event.status] || 'upcoming'\n        this.$message.success(`${action}成功`)\n      } catch (error) {\n        // 用户取消操作\n      }\n    },\n\n    async deleteEvent(event) {\n      try {\n        await this.$confirm(`确定要删除活动 \"${event.title}\" 吗？此操作不可恢复。`, '确认删除', {\n          confirmButtonText: '确定',\n          cancelButtonText: '取消',\n          type: 'warning'\n        })\n        \n        // 这里可以添加API调用来删除活动\n        this.$message.success('活动删除成功')\n        this.loadData()\n      } catch (error) {\n        // 用户取消操作\n      }\n    },\n\n    refreshData() {\n      this.loadData()\n      this.loadStatistics()\n      this.$message.success('数据已刷新')\n    },\n\n    // 辅助方法\n    getStatusType(status) {\n      const types = {\n        'active': 'success',\n        'upcoming': 'info',\n        'ended': 'danger'\n      }\n      return types[status] || 'info'\n    },\n\n    getStatusText(status) {\n      const texts = {\n        'active': '进行中',\n        'upcoming': '即将开始',\n        'ended': '已结束'\n      }\n      return texts[status] || status\n    },\n\n    getStatusButtonType(status) {\n      const types = {\n        'active': 'warning',\n        'upcoming': 'success',\n        'ended': 'primary'\n      }\n      return types[status] || 'primary'\n    },\n\n    getStatusActionText(status) {\n      const actions = {\n        'active': '结束活动',\n        'upcoming': '开始活动',\n        'ended': '重新激活'\n      }\n      return actions[status] || '操作'\n    },\n\n    formatDate(dateString) {\n      const date = new Date(dateString)\n      return date.toLocaleString('zh-CN', {\n        year: 'numeric',\n        month: '2-digit',\n        day: '2-digit',\n        hour: '2-digit',\n        minute: '2-digit'\n      })\n    },\n\n    truncateText(text, maxLength) {\n      if (!text) return ''\n      return text.length > maxLength ? text.substring(0, maxLength) + '...' : text\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.community-events {\n  padding: 20px;\n\n  h1 {\n    color: #303133;\n    margin-bottom: 10px;\n  }\n\n  p {\n    color: #909399;\n    margin-bottom: 30px;\n  }\n}\n\n.stats-container {\n  margin-bottom: 30px;\n}\n\n.stat-card {\n  text-align: center;\n\n  .stat-content {\n    padding: 20px 0;\n\n    .stat-number {\n      font-size: 32px;\n      font-weight: bold;\n      color: #303133;\n      margin-bottom: 10px;\n\n      &.text-success {\n        color: #67C23A;\n      }\n\n      &.text-info {\n        color: #409EFF;\n      }\n\n      &.text-warning {\n        color: #E6A23C;\n      }\n    }\n\n    .stat-label {\n      font-size: 14px;\n      color: #909399;\n    }\n  }\n}\n\n.action-bar {\n  margin-bottom: 20px;\n}\n\n.filter-card {\n  margin-bottom: 20px;\n}\n\n.filter-form {\n  display: flex;\n  flex-wrap: wrap;\n  align-items: center;\n}\n\n.list-card {\n  margin-bottom: 20px;\n}\n\n.card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.event-info {\n  .event-title {\n    font-weight: bold;\n    color: #303133;\n    margin-bottom: 5px;\n  }\n\n  .event-description {\n    color: #606266;\n    margin-bottom: 8px;\n    line-height: 1.5;\n  }\n\n  .event-meta {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    flex-wrap: wrap;\n\n    .event-location {\n      color: #909399;\n      font-size: 12px;\n    }\n  }\n}\n\