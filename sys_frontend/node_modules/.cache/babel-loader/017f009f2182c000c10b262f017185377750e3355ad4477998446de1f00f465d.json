{"ast":null,"code":"import { getTopicList, getTopicStatistics, createTopic, updateTopic, deleteTopic, toggleTopicStatus } from '@/api/community';\nexport default {\n  name: 'CommunityTopics',\n  data() {\n    return {\n      statistics: {\n        totalTopics: 0,\n        activeTopics: 0,\n        hotTopics: 0,\n        totalDiscussions: 0\n      },\n      topics: [],\n      searchKeyword: '',\n      filterStatus: '',\n      currentPage: 1,\n      pageSize: 10,\n      total: 0,\n      loading: false,\n      dialogVisible: false,\n      dialogTitle: '',\n      form: {\n        title: '',\n        description: '',\n        status: 'active',\n        heat_level: 1,\n        icon: ''\n      },\n      rules: {\n        title: [{\n          required: true,\n          message: '请输入话题标题',\n          trigger: 'blur'\n        }, {\n          min: 2,\n          max: 100,\n          message: '标题长度应在 2-100 个字符之间',\n          trigger: 'blur'\n        }]\n      }\n    };\n  },\n  created() {\n    this.loadData();\n    this.loadStatistics();\n  },\n  methods: {\n    async loadData() {\n      this.loading = true;\n      try {\n        const params = {\n          search: this.searchKeyword,\n          status: this.filterStatus,\n          page: this.currentPage,\n          page_size: this.pageSize\n        };\n        const response = await getTopicList(params);\n        if (response.data) {\n          this.topics = response.data.results || [];\n          this.total = response.data.count || 0;\n        }\n      } catch (error) {\n        this.$message.error('加载话题数据失败');\n        console.error('加载话题数据失败:', error);\n      } finally {\n        this.loading = false;\n      }\n    },\n    async loadStatistics() {\n      try {\n        const response = await getTopicStatistics();\n        if (response.data) {\n          this.statistics = response.data;\n        }\n      } catch (error) {\n        console.error('加载统计数据失败:', error);\n      }\n    },\n    createTopic() {\n      this.dialogTitle = '创建话题';\n      this.form = {\n        title: '',\n        description: '',\n        tag_id: null,\n        status: 'active',\n        heat_level: 1,\n        icon: ''\n      };\n      this.dialogVisible = true;\n    },\n    editTopic(topic) {\n      this.dialogTitle = '编辑话题';\n      this.form = {\n        title: topic.title,\n        description: topic.description,\n        status: topic.status,\n        heat_level: topic.heat_level,\n        icon: topic.icon\n      };\n      this.currentTopicId = topic.id;\n      this.dialogVisible = true;\n    },\n    async saveTopic() {\n      this.$refs.form.validate(async valid => {\n        if (valid) {\n          try {\n            if (this.currentTopicId) {\n              // 更新话题\n              await updateTopic(this.currentTopicId, this.form);\n              this.$message.success('更新话题成功');\n            } else {\n              // 创建话题\n              await createTopic(this.form);\n              this.$message.success('创建话题成功');\n            }\n            this.dialogVisible = false;\n            this.loadData();\n            this.loadStatistics();\n          } catch (error) {\n            this.$message.error('保存话题失败');\n            console.error('保存话题失败:', error);\n          }\n        }\n      });\n    },\n    async deleteTopicConfirm(topic) {\n      this.$confirm(`确定要删除话题 \"${topic.title}\" 吗？`, '确认', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'danger'\n      }).then(async () => {\n        try {\n          await deleteTopic(topic.id);\n          this.$message.success('删除话题成功');\n          this.loadData();\n          this.loadStatistics();\n        } catch (error) {\n          this.$message.error('删除话题失败');\n          console.error('删除话题失败:', error);\n        }\n      }).catch(() => {});\n    },\n    async closeTopic(topic) {\n      try {\n        await toggleTopicStatus(topic.id);\n        this.$message.success('话题已关闭');\n        this.loadData();\n      } catch (error) {\n        this.$message.error('关闭话题失败');\n        console.error('关闭话题失败:', error);\n      }\n    },\n    async openTopic(topic) {\n      try {\n        await toggleTopicStatus(topic.id);\n        this.$message.success('话题已开启');\n        this.loadData();\n      } catch (error) {\n        this.$message.error('开启话题失败');\n        console.error('开启话题失败:', error);\n      }\n    },\n    refreshData() {\n      this.loadData();\n      this.loadStatistics();\n    },\n    searchTopics() {\n      this.currentPage = 1;\n      this.loadData();\n    },\n    viewTopic(topic) {\n      // TODO: 查看话题详情\n      this.$message.info(`查看话题: ${topic.title}`);\n    },\n    handleSizeChange(val) {\n      this.pageSize = val;\n      this.loadData();\n    },\n    handleCurrentChange(val) {\n      this.currentPage = val;\n      this.loadData();\n    },\n    getStatusType(status) {\n      const types = {\n        'active': 'success',\n        'hot': 'danger',\n        'closed': 'info'\n      };\n      return types[status] || 'info';\n    },\n    getStatusText(status) {\n      const texts = {\n        'active': '活跃',\n        'hot': '热门',\n        'closed': '已关闭'\n      };\n      return texts[status] || status;\n    },\n    getHeatType(heatLevel) {\n      const types = {\n        1: 'info',\n        2: 'warning',\n        3: 'danger'\n      };\n      return types[heatLevel] || 'info';\n    },\n    getHeatText(heatLevel) {\n      const texts = {\n        1: '普通',\n        2: '热门',\n        3: '火爆'\n      };\n      return texts[heatLevel] || '未知';\n    }\n  }\n};","map":{"version":3,"names":["getTopicList","getTopicStatistics","createTopic","updateTopic","deleteTopic","toggleTopicStatus","name","data","statistics","totalTopics","activeTopics","hotTopics","totalDiscussions","topics","searchKeyword","filterStatus","currentPage","pageSize","total","loading","dialogVisible","dialogTitle","form","title","description","status","heat_level","icon","rules","required","message","trigger","min","max","created","loadData","loadStatistics","methods","params","search","page","page_size","response","results","count","error","$message","console","tag_id","editTopic","topic","currentTopicId","id","saveTopic","$refs","validate","valid","success","deleteTopicConfirm","$confirm","confirmButtonText","cancelButtonText","type","then","catch","closeTopic","openTopic","refreshData","searchTopics","viewTopic","info","handleSizeChange","val","handleCurrentChange","getStatusType","types","getStatusText","texts","getHeatType","heatLevel","getHeatText"],"sources":["src/views/community/CommunityTopics.vue"],"sourcesContent":["<template>\n  <div class=\"topic-management\">\n    <h1>热门话题管理</h1>\n    <p>管理社区热门话题和讨论</p>\n\n    <!-- 话题统计 -->\n    <div class=\"stats-container\">\n      <el-row :gutter=\"20\">\n        <el-col :span=\"6\">\n          <el-card class=\"stat-card\">\n            <div class=\"stat-content\">\n              <div class=\"stat-number\">{{ statistics.totalTopics || 0 }}</div>\n              <div class=\"stat-label\">总话题数</div>\n            </div>\n          </el-card>\n        </el-col>\n        <el-col :span=\"6\">\n          <el-card class=\"stat-card\">\n            <div class=\"stat-content\">\n              <div class=\"stat-number text-success\">{{ statistics.activeTopics || 0 }}</div>\n              <div class=\"stat-label\">活跃话题</div>\n            </div>\n          </el-card>\n        </el-col>\n        <el-col :span=\"6\">\n          <el-card class=\"stat-card\">\n            <div class=\"stat-content\">\n              <div class=\"stat-number text-warning\">{{ statistics.hotTopics || 0 }}</div>\n              <div class=\"stat-label\">热门话题</div>\n            </div>\n          </el-card>\n        </el-col>\n        <el-col :span=\"6\">\n          <el-card class=\"stat-card\">\n            <div class=\"stat-content\">\n              <div class=\"stat-number text-info\">{{ statistics.totalDiscussions || 0 }}</div>\n              <div class=\"stat-label\">总讨论数</div>\n            </div>\n          </el-card>\n        </el-col>\n      </el-row>\n    </div>\n\n    <!-- 操作栏 -->\n    <div class=\"action-bar\">\n      <el-button type=\"primary\" @click=\"createTopic\">\n        <i class=\"el-icon-plus\"></i> 创建话题\n      </el-button>\n      <el-button @click=\"refreshData\">\n        <i class=\"el-icon-refresh\"></i> 刷新\n      </el-button>\n    </div>\n\n    <!-- 话题列表 -->\n    <el-card>\n      <div slot=\"header\" class=\"card-header\">\n        <span>话题列表</span>\n        <div class=\"header-actions\">\n          <el-input v-model=\"searchKeyword\" placeholder=\"搜索话题\" prefix-icon=\"el-icon-search\"\n            style=\"width: 200px; margin-right: 10px\" @keyup.enter=\"searchTopics\"></el-input>\n          <el-select v-model=\"filterStatus\" placeholder=\"状态筛选\" style=\"width: 120px; margin-right: 10px\">\n            <el-option label=\"全部\" value=\"\"></el-option>\n            <el-option label=\"活跃\" value=\"active\"></el-option>\n            <el-option label=\"热门\" value=\"hot\"></el-option>\n            <el-option label=\"已关闭\" value=\"closed\"></el-option>\n          </el-select>\n          <el-button type=\"primary\" size=\"small\" @click=\"searchTopics\">搜索</el-button>\n        </div>\n      </div>\n\n      <div class=\"topic-list\">\n        <div v-if=\"topics.length === 0\" class=\"empty-state\">\n          <i class=\"el-icon-chat-dot-round\"></i>\n          <p>暂无话题数据</p>\n        </div>\n\n        <div v-else class=\"topic-grid\">\n          <div v-for=\"topic in topics\" :key=\"topic.id\" class=\"topic-card\">\n            <div class=\"topic-header\">\n              <div class=\"topic-icon\">\n                <i :class=\"topic.icon || 'el-icon-chat-dot-round'\"></i>\n              </div>\n              <div class=\"topic-info\">\n                <h4>{{ topic.title }}</h4>\n                <p>{{ topic.description }}</p>\n                <div class=\"topic-meta\">\n                  <el-tag :type=\"getStatusType(topic.status)\" size=\"mini\">\n                    {{ getStatusText(topic.status) }}\n                  </el-tag>\n                  <el-tag :type=\"getHeatType(topic.heat_level)\" size=\"mini\">\n                    {{ getHeatText(topic.heat_level) }}\n                  </el-tag>\n                  <span class=\"topic-stats\">\n                    <i class=\"el-icon-view\"></i> {{ topic.view_count }}\n                    <i class=\"el-icon-chat-dot-round\"></i> {{ topic.discussion_count }}\n                    <i class=\"el-icon-thumb\"></i> {{ topic.like_count }}\n                  </span>\n                </div>\n              </div>\n            </div>\n\n            <div class=\"topic-actions\">\n              <el-button type=\"text\" size=\"mini\" @click=\"viewTopic(topic)\">查看</el-button>\n              <el-button type=\"text\" size=\"mini\" @click=\"editTopic(topic)\">编辑</el-button>\n              <el-button type=\"danger\" size=\"mini\" @click=\"deleteTopicConfirm(topic)\">\n                删除\n              </el-button>\n              <el-button v-if=\"topic.status === 'active'\" type=\"text\" size=\"mini\" @click=\"closeTopic(topic)\">\n                关闭\n              </el-button>\n              <el-button v-else type=\"text\" size=\"mini\" @click=\"openTopic(topic)\">\n                开启\n              </el-button>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- 分页 -->\n      <div class=\"pagination-container\">\n        <el-pagination @size-change=\"handleSizeChange\" @current-change=\"handleCurrentChange\" :current-page=\"currentPage\"\n          :page-sizes=\"[10, 20, 50, 100]\" :page-size=\"pageSize\" layout=\"total, sizes, prev, pager, next, jumper\"\n          :total=\"total\"></el-pagination>\n      </div>\n    </el-card>\n\n    <!-- 创建/编辑话题对话框 -->\n    <el-dialog :title=\"dialogTitle\" :visible.sync=\"dialogVisible\" width=\"600px\">\n      <el-form ref=\"form\" :model=\"form\" :rules=\"rules\" label-width=\"100px\">\n        <el-form-item label=\"话题标题\" prop=\"title\">\n          <el-input v-model=\"form.title\" placeholder=\"请输入话题标题\" />\n        </el-form-item>\n        <el-form-item label=\"话题描述\">\n          <el-input v-model=\"form.description\" type=\"textarea\" rows=\"3\" placeholder=\"请输入话题描述\" />\n        </el-form-item>\n\n        <el-form-item label=\"话题状态\">\n          <el-select v-model=\"form.status\" placeholder=\"请选择话题状态\">\n            <el-option label=\"活跃\" value=\"active\" />\n            <el-option label=\"热门\" value=\"hot\" />\n            <el-option label=\"已关闭\" value=\"closed\" />\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"热度等级\">\n          <el-select v-model=\"form.heat_level\" placeholder=\"请选择热度等级\">\n            <el-option label=\"普通\" value=\"1\" />\n            <el-option label=\"热门\" value=\"2\" />\n            <el-option label=\"火爆\" value=\"3\" />\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"图标类名\">\n          <el-input v-model=\"form.icon\" placeholder=\"请输入图标类名，如：el-icon-heart\" />\n        </el-form-item>\n      </el-form>\n      <span slot=\"footer\" class=\"dialog-footer\">\n        <el-button @click=\"dialogVisible = false\">取消</el-button>\n        <el-button type=\"primary\" @click=\"saveTopic\">确定</el-button>\n      </span>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport { getTopicList, getTopicStatistics, createTopic, updateTopic, deleteTopic, toggleTopicStatus } from '@/api/community'\n\nexport default {\n  name: 'CommunityTopics',\n  data() {\n    return {\n      statistics: {\n        totalTopics: 0,\n        activeTopics: 0,\n        hotTopics: 0,\n        totalDiscussions: 0\n      },\n      topics: [],\n      searchKeyword: '',\n      filterStatus: '',\n      currentPage: 1,\n      pageSize: 10,\n      total: 0,\n      loading: false,\n      dialogVisible: false,\n      dialogTitle: '',\n      form: {\n        title: '',\n        description: '',\n        status: 'active',\n        heat_level: 1,\n        icon: ''\n      },\n      rules: {\n        title: [\n          { required: true, message: '请输入话题标题', trigger: 'blur' },\n          { min: 2, max: 100, message: '标题长度应在 2-100 个字符之间', trigger: 'blur' }\n        ]\n      }\n    }\n  },\n  created() {\n    this.loadData()\n    this.loadStatistics()\n  },\n  methods: {\n    async loadData() {\n      this.loading = true\n      try {\n        const params = {\n          search: this.searchKeyword,\n          status: this.filterStatus,\n          page: this.currentPage,\n          page_size: this.pageSize\n        }\n        const response = await getTopicList(params)\n        if (response.data) {\n          this.topics = response.data.results || []\n          this.total = response.data.count || 0\n        }\n      } catch (error) {\n        this.$message.error('加载话题数据失败')\n        console.error('加载话题数据失败:', error)\n      } finally {\n        this.loading = false\n      }\n    },\n\n    async loadStatistics() {\n      try {\n        const response = await getTopicStatistics()\n        if (response.data) {\n          this.statistics = response.data\n        }\n      } catch (error) {\n        console.error('加载统计数据失败:', error)\n      }\n    },\n\n    createTopic() {\n      this.dialogTitle = '创建话题'\n      this.form = {\n        title: '',\n        description: '',\n        tag_id: null,\n        status: 'active',\n        heat_level: 1,\n        icon: ''\n      }\n      this.dialogVisible = true\n    },\n\n    editTopic(topic) {\n      this.dialogTitle = '编辑话题'\n      this.form = {\n        title: topic.title,\n        description: topic.description,\n        status: topic.status,\n        heat_level: topic.heat_level,\n        icon: topic.icon\n      }\n      this.currentTopicId = topic.id\n      this.dialogVisible = true\n    },\n\n    async saveTopic() {\n      this.$refs.form.validate(async (valid) => {\n        if (valid) {\n          try {\n            if (this.currentTopicId) {\n              // 更新话题\n              await updateTopic(this.currentTopicId, this.form)\n              this.$message.success('更新话题成功')\n            } else {\n              // 创建话题\n              await createTopic(this.form)\n              this.$message.success('创建话题成功')\n            }\n            this.dialogVisible = false\n            this.loadData()\n            this.loadStatistics()\n          } catch (error) {\n            this.$message.error('保存话题失败')\n            console.error('保存话题失败:', error)\n          }\n        }\n      })\n    },\n\n    async deleteTopicConfirm(topic) {\n      this.$confirm(`确定要删除话题 \"${topic.title}\" 吗？`, '确认', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'danger'\n      }).then(async () => {\n        try {\n          await deleteTopic(topic.id)\n          this.$message.success('删除话题成功')\n          this.loadData()\n          this.loadStatistics()\n        } catch (error) {\n          this.$message.error('删除话题失败')\n          console.error('删除话题失败:', error)\n        }\n      }).catch(() => { })\n    },\n\n    async closeTopic(topic) {\n      try {\n        await toggleTopicStatus(topic.id)\n        this.$message.success('话题已关闭')\n        this.loadData()\n      } catch (error) {\n        this.$message.error('关闭话题失败')\n        console.error('关闭话题失败:', error)\n      }\n    },\n\n    async openTopic(topic) {\n      try {\n        await toggleTopicStatus(topic.id)\n        this.$message.success('话题已开启')\n        this.loadData()\n      } catch (error) {\n        this.$message.error('开启话题失败')\n        console.error('开启话题失败:', error)\n      }\n    },\n\n    refreshData() {\n      this.loadData()\n      this.loadStatistics()\n    },\n\n    searchTopics() {\n      this.currentPage = 1\n      this.loadData()\n    },\n\n    viewTopic(topic) {\n      // TODO: 查看话题详情\n      this.$message.info(`查看话题: ${topic.title}`)\n    },\n\n    handleSizeChange(val) {\n      this.pageSize = val\n      this.loadData()\n    },\n\n    handleCurrentChange(val) {\n      this.currentPage = val\n      this.loadData()\n    },\n\n    getStatusType(status) {\n      const types = {\n        'active': 'success',\n        'hot': 'danger',\n        'closed': 'info'\n      }\n      return types[status] || 'info'\n    },\n\n    getStatusText(status) {\n      const texts = {\n        'active': '活跃',\n        'hot': '热门',\n        'closed': '已关闭'\n      }\n      return texts[status] || status\n    },\n\n    getHeatType(heatLevel) {\n      const types = {\n        1: 'info',\n        2: 'warning',\n        3: 'danger'\n      }\n      return types[heatLevel] || 'info'\n    },\n\n    getHeatText(heatLevel) {\n      const texts = {\n        1: '普通',\n        2: '热门',\n        3: '火爆'\n      }\n      return texts[heatLevel] || '未知'\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.community-topics {\n  padding: 20px;\n\n  h1 {\n    color: #303133;\n    margin-bottom: 10px;\n  }\n\n  p {\n    color: #909399;\n    margin-bottom: 30px;\n  }\n}\n\n.stats-container {\n  margin-bottom: 30px;\n}\n\n.stat-card {\n  text-align: center;\n\n  .stat-content {\n    padding: 20px 0;\n\n    .stat-number {\n      font-size: 32px;\n      font-weight: bold;\n      color: #303133;\n      margin-bottom: 10px;\n\n      &.text-success {\n        color: #67C23A;\n      }\n\n      &.text-warning {\n        color: #E6A23C;\n      }\n\n      &.text-info {\n        color: #409EFF;\n      }\n    }\n\n    .stat-label {\n      font-size: 14px;\n      color: #909399;\n    }\n  }\n}\n\n.action-bar {\n  margin-bottom: 20px;\n}\n\n.card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.empty-state {\n  text-align: center;\n  padding: 60px 20px;\n  color: #909399;\n\n  i {\n    font-size: 64px;\n    margin-bottom: 20px;\n    display: block;\n  }\n\n  p {\n    margin: 0;\n    font-size: 16px;\n  }\n}\n\n.topic-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));\n  gap: 20px;\n  margin-top: 20px;\n}\n\n.topic-card {\n  background: #fff;\n  border-radius: 8px;\n  padding: 20px;\n  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);\n  transition: all 0.3s ease;\n\n  &:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);\n  }\n\n  .topic-header {\n    display: flex;\n    align-items: flex-start;\n    gap: 15px;\n    margin-bottom: 15px;\n\n    .topic-icon {\n      font-size: 32px;\n      color: #409EFF;\n      width: 40px;\n      text-align: center;\n    }\n\n    .topic-info {\n      flex: 1;\n\n      h4 {\n        margin: 0 0 8px 0;\n        color: #303133;\n        font-size: 16px;\n      }\n\n      p {\n        margin: 0 0 10px 0;\n        color: #606266;\n        font-size: 14px;\n        line-height: 1.5;\n      }\n\n      .topic-meta {\n        display: flex;\n        align-items: center;\n        gap: 10px;\n        flex-wrap: wrap;\n\n        .topic-stats {\n          font-size: 12px;\n          color: #909399;\n          display: flex;\n          align-items: center;\n          gap: 15px;\n\n          i {\n            margin-right: 3px;\n          }\n        }\n      }\n    }\n  }\n\n  .topic-actions {\n    display: flex;\n    justify-content: flex-end;\n    gap: 10px;\n  }\n}\n\n.pagination-container {\n  margin-top: 20px;\n  text-align: right;\n}\n</style>"],"mappings":"AAmKA,SAAAA,YAAA,EAAAC,kBAAA,EAAAC,WAAA,EAAAC,WAAA,EAAAC,WAAA,EAAAC,iBAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,UAAA;QACAC,WAAA;QACAC,YAAA;QACAC,SAAA;QACAC,gBAAA;MACA;MACAC,MAAA;MACAC,aAAA;MACAC,YAAA;MACAC,WAAA;MACAC,QAAA;MACAC,KAAA;MACAC,OAAA;MACAC,aAAA;MACAC,WAAA;MACAC,IAAA;QACAC,KAAA;QACAC,WAAA;QACAC,MAAA;QACAC,UAAA;QACAC,IAAA;MACA;MACAC,KAAA;QACAL,KAAA,GACA;UAAAM,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,GACA;UAAAC,GAAA;UAAAC,GAAA;UAAAH,OAAA;UAAAC,OAAA;QAAA;MAEA;IACA;EACA;EACAG,QAAA;IACA,KAAAC,QAAA;IACA,KAAAC,cAAA;EACA;EACAC,OAAA;IACA,MAAAF,SAAA;MACA,KAAAhB,OAAA;MACA;QACA,MAAAmB,MAAA;UACAC,MAAA,OAAAzB,aAAA;UACAW