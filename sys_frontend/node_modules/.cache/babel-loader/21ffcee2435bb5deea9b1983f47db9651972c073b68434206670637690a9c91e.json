{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nimport { getLoveTests, createLoveTest, updateLoveTest, deleteLoveTest } from '@/api/couple';\nexport default {\n  name: 'TestManagement',\n  data() {\n    return {\n      loading: false,\n      tests: [],\n      total: 0,\n      currentPage: 1,\n      pageSize: 10,\n      filterForm: {\n        search: '',\n        category: ''\n      },\n      dialogVisible: false,\n      dialogTitle: '',\n      form: {\n        id: '',\n        question: '',\n        correct_answer: '',\n        options: '',\n        category_id: ''\n      },\n      fileList: []\n    };\n  },\n  created() {\n    this.loadData();\n  },\n  methods: {\n    async loadData() {\n      this.loading = true;\n      try {\n        const params = {\n          search: this.filterForm.search,\n          category: this.filterForm.category\n        };\n        const response = await getLoveTests(params);\n        this.tests = response.data;\n        this.total = this.tests.length;\n      } catch (error) {\n        this.$message.error('加载失败');\n      } finally {\n        this.loading = false;\n      }\n    },\n    handleSearch() {\n      this.currentPage = 1;\n      this.loadData();\n    },\n    resetFilter() {\n      this.filterForm = {\n        search: '',\n        category: ''\n      };\n      this.currentPage = 1;\n      this.loadData();\n    },\n    handleSizeChange(val) {\n      this.pageSize = val;\n      this.loadData();\n    },\n    handleCurrentChange(val) {\n      this.currentPage = val;\n      this.loadData();\n    },\n    addTest() {\n      this.dialogTitle = '添加测试';\n      this.form = {\n        id: '',\n        question: '',\n        correct_answer: '',\n        options: '',\n        category_id: ''\n      };\n      this.fileList = [];\n      this.dialogVisible = true;\n    },\n    editTest(test) {\n      this.dialogTitle = '编辑测试';\n      // 将数组形式的options转换为逗号分隔的字符串\n      const optionsStr = Array.isArray(test.options) ? test.options.join(',') : test.options;\n      this.form = {\n        ...test,\n        options: optionsStr,\n        category_id: test.category_id || ''\n      };\n      this.fileList = [];\n      this.dialogVisible = true;\n    },\n    viewTest(test) {\n      // 查看详情\n      console.log('查看测试详情:', test);\n      this.$message.info('查看详情功能开发中');\n    },\n    async saveTest() {\n      try {\n        // 转换options为数组格式\n        const formData = {\n          ...this.form,\n          options: this.form.options.split(',').map(opt => opt.trim())\n        };\n        if (this.form.id) {\n          await updateLoveTest(this.form.id, formData);\n        } else {\n          await createLoveTest(formData);\n        }\n        this.$message.success('保存成功');\n        this.dialogVisible = false;\n        this.loadData();\n      } catch (error) {\n        this.$message.error('保存失败');\n      }\n    },\n    async deleteTest(test) {\n      this.$confirm('确定要删除这个测试吗？', '确认删除', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(async () => {\n        try {\n          await deleteLoveTest(test.id);\n          this.$message.success('删除成功');\n          this.loadData();\n        } catch (error) {\n          this.$message.error('删除失败');\n        }\n      }).catch(() => {});\n    },\n    handlePreview(file) {\n      console.log('预览文件:', file);\n    },\n    handleRemove(file, fileList) {\n      console.log('删除文件:', file, fileList);\n    },\n    getCategoryName(categoryId) {\n      const categories = {\n        '1': '沟通交流',\n        '2': '亲密关系',\n        '3': '信任关系',\n        '4': '未来规划',\n        '5': '冲突解决'\n      };\n      return categories[categoryId] || '未知分类';\n    }\n  }\n};","map":{"version":3,"names":["getLoveTests","createLoveTest","updateLoveTest","deleteLoveTest","name","data","loading","tests","total","currentPage","pageSize","filterForm","search","category","dialogVisible","dialogTitle","form","id","question","correct_answer","options","category_id","fileList","created","loadData","methods","params","response","length","error","$message","handleSearch","resetFilter","handleSizeChange","val","handleCurrentChange","addTest","editTest","test","optionsStr","Array","isArray","join","viewTest","console","log","info","saveTest","formData","split","map","opt","trim","success","deleteTest","$confirm","confirmButtonText","cancelButtonText","type","then","catch","handlePreview","file","handleRemove","getCategoryName","categoryId","categories"],"sources":["src/views/couple/TestManagement.vue"],"sourcesContent":["<template>\n  <div class=\"test-management\">\n\n    <el-card class=\"filter-card\">\n      <el-form :inline=\"true\" :model=\"filterForm\" class=\"filter-form\">\n        <el-form-item label=\"搜索\">\n          <el-input v-model=\"filterForm.search\" placeholder=\"搜索测试标题\" clearable @clear=\"handleSearch\"\n            @keyup.enter=\"handleSearch\" style=\"width: 200px\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"分类\">\n          <el-select v-model=\"filterForm.category\" placeholder=\"选择分类\" clearable>\n            <el-option label=\"全部\" value=\"\"></el-option>\n            <el-option label=\"沟通交流\" value=\"1\"></el-option>\n            <el-option label=\"亲密关系\" value=\"2\"></el-option>\n            <el-option label=\"信任关系\" value=\"3\"></el-option>\n            <el-option label=\"未来规划\" value=\"4\"></el-option>\n            <el-option label=\"冲突解决\" value=\"5\"></el-option>\n          </el-select>\n        </el-form-item>\n        <el-form-item>\n          <el-button type=\"primary\" @click=\"handleSearch\">搜索</el-but  ton>\n          <el-button @click=\"resetFilter\">重置</el-button>\n          <el-button type=\"primary\" @click=\"addTest\">\n            <i class=\"el-icon-plus\"></i> 添加测试\n          </el-button>\n        </el-form-item>\n      </el-form>\n    </el-card>\n\n    <el-card class=\"list-card\">\n      <div slot=\"header\" class=\"card-header\">\n        <span>测试列表</span>\n      </div>\n\n      <el-table :data=\"tests\" v-loading=\"loading\" border style=\"width: 100%\">\n        <el-table-column prop=\"id\" label=\"ID\" width=\"80\" align=\"center\"></el-table-column>\n        <el-table-column prop=\"question\" label=\"测试问题\" min-width=\"200\"></el-table-column>\n        <el-table-column label=\"分类\" width=\"100\" align=\"center\">\n          <template slot-scope=\"scope\">\n            {{ getCategoryName(scope.row.category_id) }}\n          </template>\n        </el-table-column>\n\n        <el-table-column prop=\"created_at\" label=\"创建时间\" width=\"150\" align=\"center\"></el-table-column>\n        <el-table-column label=\"操作\" width=\"150\" align=\"center\">\n          <template slot-scope=\"scope\">\n            <el-button type=\"text\" size=\"mini\" @click=\"viewTest(scope.row)\">详情</el-button>\n            <el-button type=\"text\" size=\"mini\" @click=\"editTest(scope.row)\">编辑</el-button>\n            <el-button type=\"text\" size=\"mini\" @click=\"deleteTest(scope.row)\" style=\"color: #F56C6C\">删除</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n\n      <div class=\"pagination-container\">\n        <el-pagination @size-change=\"handleSizeChange\" @current-change=\"handleCurrentChange\" :current-page=\"currentPage\"\n          :page-sizes=\"[10, 20, 50, 100]\" :page-size=\"pageSize\" layout=\"total, sizes, prev, pager, next, jumper\"\n          :total=\"total\"></el-pagination>\n      </div>\n    </el-card>\n\n    <!-- 添加/编辑对话框 -->\n    <el-dialog :title=\"dialogTitle\" :visible.sync=\"dialogVisible\" width=\"600px\" :modal=\"false\">\n      <el-form :model=\"form\" label-width=\"100px\">\n        <el-form-item label=\"测试问题\" required>\n          <el-input type=\"textarea\" v-model=\"form.question\" placeholder=\"请输入测试问题\" rows=\"3\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"正确答案\" required>\n          <el-input v-model=\"form.correct_answer\" placeholder=\"请输入正确答案\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"选项列表\" required>\n          <el-input type=\"textarea\" v-model=\"form.options\" placeholder=\"请输入选项列表，以逗号分隔\" rows=\"3\"></el-input>\n        </el-form-item>\n\n        <el-form-item label=\"分类\" required>\n          <el-select v-model=\"form.category_id\" placeholder=\"选择分类\">\n            <el-option label=\"沟通交流\" value=\"1\"></el-option>\n            <el-option label=\"亲密关系\" value=\"2\"></el-option>\n            <el-option label=\"信任关系\" value=\"3\"></el-option>\n            <el-option label=\"未来规划\" value=\"4\"></el-option>\n            <el-option label=\"冲突解决\" value=\"5\"></el-option>\n          </el-select>\n        </el-form-item>\n      </el-form>\n      <div slot=\"footer\" class=\"dialog-footer\">\n        <el-button @click=\"dialogVisible = false\">取消</el-button>\n        <el-button type=\"primary\" @click=\"saveTest\">保存</el-button>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport {\n  getLoveTests,\n  createLoveTest,\n  updateLoveTest,\n  deleteLoveTest\n} from '@/api/couple'\n\nexport default {\n  name: 'TestManagement',\n  data() {\n    return {\n      loading: false,\n      tests: [],\n      total: 0,\n      currentPage: 1,\n      pageSize: 10,\n      filterForm: {\n        search: '',\n        category: ''\n      },\n      dialogVisible: false,\n      dialogTitle: '',\n      form: {\n        id: '',\n        question: '',\n        correct_answer: '',\n        options: '',\n        category_id: ''\n      },\n      fileList: []\n    }\n  },\n  created() {\n    this.loadData()\n  },\n  methods: {\n    async loadData() {\n      this.loading = true\n      try {\n        const params = {\n          search: this.filterForm.search,\n          category: this.filterForm.category\n        }\n        const response = await getLoveTests(params)\n        this.tests = response.data\n        this.total = this.tests.length\n      } catch (error) {\n        this.$message.error('加载失败')\n      } finally {\n        this.loading = false\n      }\n    },\n    handleSearch() {\n      this.currentPage = 1\n      this.loadData()\n    },\n    resetFilter() {\n      this.filterForm = {\n        search: '',\n        category: ''\n      }\n      this.currentPage = 1\n      this.loadData()\n    },\n    handleSizeChange(val) {\n      this.pageSize = val\n      this.loadData()\n    },\n    handleCurrentChange(val) {\n      this.currentPage = val\n      this.loadData()\n    },\n    addTest() {\n      this.dialogTitle = '添加测试'\n      this.form = {\n        id: '',\n        question: '',\n        correct_answer: '',\n        options: '',\n        category_id: ''\n      }\n      this.fileList = []\n      this.dialogVisible = true\n    },\n    editTest(test) {\n      this.dialogTitle = '编辑测试'\n      // 将数组形式的options转换为逗号分隔的字符串\n      const optionsStr = Array.isArray(test.options) ? test.options.join(',') : test.options\n      this.form = {\n        ...test,\n        options: optionsStr,\n        category_id: test.category_id || ''\n      }\n      this.fileList = []\n      this.dialogVisible = true\n    },\n    viewTest(test) {\n      // 查看详情\n      console.log('查看测试详情:', test)\n      this.$message.info('查看详情功能开发中')\n    },\n    async saveTest() {\n      try {\n        // 转换options为数组格式\n        const formData = {\n          ...this.form,\n          options: this.form.options.split(',').map(opt => opt.trim())\n        }\n\n        if (this.form.id) {\n          await updateLoveTest(this.form.id, formData)\n        } else {\n          await createLoveTest(formData)\n        }\n        this.$message.success('保存成功')\n        this.dialogVisible = false\n        this.loadData()\n      } catch (error) {\n        this.$message.error('保存失败')\n      }\n    },\n    async deleteTest(test) {\n      this.$confirm('确定要删除这个测试吗？', '确认删除', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(async () => {\n        try {\n          await deleteLoveTest(test.id)\n          this.$message.success('删除成功')\n          this.loadData()\n        } catch (error) {\n          this.$message.error('删除失败')\n        }\n      }).catch(() => { })\n    },\n    handlePreview(file) {\n      console.log('预览文件:', file)\n    },\n    handleRemove(file, fileList) {\n      console.log('删除文件:', file, fileList)\n    },\n    getCategoryName(categoryId) {\n      const categories = {\n        '1': '沟通交流',\n        '2': '亲密关系',\n        '3': '信任关系',\n        '4': '未来规划',\n        '5': '冲突解决'\n      }\n      return categories[categoryId] || '未知分类'\n    }\n  }\n}\n</script>\n\n<style scoped>\n.test-management {\n  padding: 20px;\n}\n\n.page-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 20px;\n}\n\n.page-header h1 {\n  margin: 0;\n  color: #303133;\n}\n\n.filter-card {\n  margin-bottom: 20px;\n}\n\n.list-card {\n  margin-bottom: 20px;\n}\n\n.card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.pagination-container {\n  margin-top: 20px;\n  text-align: right;\n}\n</style>"],"mappings":";;AA4FA,SACAA,YAAA,EACAC,cAAA,EACAC,cAAA,EACAC,cAAA,QACA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,OAAA;MACAC,KAAA;MACAC,KAAA;MACAC,WAAA;MACAC,QAAA;MACAC,UAAA;QACAC,MAAA;QACAC,QAAA;MACA;MACAC,aAAA;MACAC,WAAA;MACAC,IAAA;QACAC,EAAA;QACAC,QAAA;QACAC,cAAA;QACAC,OAAA;QACAC,WAAA;MACA;MACAC,QAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,QAAA;EACA;EACAC,OAAA;IACA,MAAAD,SAAA;MACA,KAAAlB,OAAA;MACA;QACA,MAAAoB,MAAA;UACAd,MAAA,OAAAD,UAAA,CAAAC,MAAA;UACAC,QAAA,OAAAF,UAAA,CAAAE;QACA;QACA,MAAAc,QAAA,SAAA3B,YAAA,CAAA0B,MAAA;QACA,KAAAnB,KAAA,GAAAoB,QAAA,CAAAtB,IAAA;QACA,KAAAG,KAAA,QAAAD,KAAA,CAAAqB,MAAA;MACA,SAAAC,KAAA;QACA,KAAAC,QAAA,CAAAD,KAAA;MACA;QACA,KAAAvB,OAAA;MACA;IACA;IACAyB,aAAA;MACA,KAAAtB,WAAA;MACA,KAAAe,QAAA;IACA;IACAQ,YAAA;MACA,KAAArB,UAAA;QACAC,MAAA;QACAC,QAAA;MACA;MACA,KAAAJ,W