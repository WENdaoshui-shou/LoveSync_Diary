{"ast":null,"code":"export default {\n  name: 'RecommendedCouples',\n  data() {\n    return {\n      loading: false,\n      couples: [],\n      total: 0,\n      currentPage: 1,\n      pageSize: 10,\n      filterForm: {\n        search: '',\n        status: ''\n      },\n      dialogVisible: false,\n      dialogTitle: '',\n      form: {\n        id: '',\n        user1_id: '',\n        user2_id: '',\n        user1_name: '',\n        user2_name: '',\n        couple_name: '',\n        relationship_start_date: '',\n        love_vow: '',\n        love_story: ''\n      }\n    };\n  },\n  created() {\n    this.loadData();\n  },\n  methods: {\n    async loadData() {\n      this.loading = true;\n      try {\n        // 这里应该调用API获取数据\n        // const response = await getCouples({ page: this.currentPage, page_size: this.pageSize, search: this.filterForm.search, status: this.filterForm.status })\n        // 模拟数据\n        this.couples = [{\n          id: 1,\n          user1_id: 1,\n          user2_id: 2,\n          user1_name: '张三',\n          user2_name: '李四',\n          couple_name: '甜蜜情侣',\n          relationship_start_date: '2025-02-14',\n          love_vow: '执子之手，与子偕老',\n          love_story: '我们在大学相遇，相知相恋'\n        }, {\n          id: 2,\n          user1_id: 3,\n          user2_id: 4,\n          user1_name: '王五',\n          user2_name: '赵六',\n          couple_name: '幸福恋人',\n          relationship_start_date: '2025-03-01',\n          love_vow: '爱你到永远',\n          love_story: '我们在工作中相识，彼此吸引'\n        }];\n        this.total = this.couples.length;\n      } catch (error) {\n        this.$message.error('加载失败');\n      } finally {\n        this.loading = false;\n      }\n    },\n    handleSearch() {\n      this.currentPage = 1;\n      this.loadData();\n    },\n    resetFilter() {\n      this.filterForm = {\n        search: '',\n        status: ''\n      };\n      this.currentPage = 1;\n      this.loadData();\n    },\n    handleSizeChange(val) {\n      this.pageSize = val;\n      this.loadData();\n    },\n    handleCurrentChange(val) {\n      this.currentPage = val;\n      this.loadData();\n    },\n    refreshData() {\n      this.loadData();\n      this.$message.success('数据已刷新');\n    },\n    viewCouple(couple) {\n      this.dialogTitle = '查看情侣详情';\n      this.form = {\n        ...couple\n      };\n      this.dialogVisible = true;\n    },\n    editCouple(couple) {\n      this.dialogTitle = '编辑情侣信息';\n      this.form = {\n        ...couple\n      };\n      this.dialogVisible = true;\n    },\n    async saveCouple() {\n      try {\n        // 这里应该调用API保存数据\n        this.$message.success('保存成功');\n        this.dialogVisible = false;\n        this.loadData();\n      } catch (error) {\n        this.$message.error('保存失败');\n      }\n    },\n    async deleteCouple(couple) {\n      this.$confirm('确定要解除这对情侣的关系吗？', '确认解除', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(async () => {\n        try {\n          // 这里应该调用API删除数据\n          this.$message.success('解除关系成功');\n          this.loadData();\n        } catch (error) {\n          this.$message.error('解除关系失败');\n        }\n      }).catch(() => {});\n    }\n  }\n};","map":{"version":3,"names":["name","data","loading","couples","total","currentPage","pageSize","filterForm","search","status","dialogVisible","dialogTitle","form","id","user1_id","user2_id","user1_name","user2_name","couple_name","relationship_start_date","love_vow","love_story","created","loadData","methods","length","error","$message","handleSearch","resetFilter","handleSizeChange","val","handleCurrentChange","refreshData","success","viewCouple","couple","editCouple","saveCouple","deleteCouple","$confirm","confirmButtonText","cancelButtonText","type","then","catch"],"sources":["src/views/couple/RecommendedCouples.vue"],"sourcesContent":["<template>\n  <div class=\"recommended-couples\">\n    <div class=\"page-header\">\n      <h1>推荐情侣管理</h1>\n      <el-button type=\"primary\" @click=\"refreshData\">\n        <i class=\"el-icon-refresh\"></i> 刷新数据\n      </el-button>\n    </div>\n\n    <el-card class=\"filter-card\">\n      <el-form :inline=\"true\" :model=\"filterForm\" class=\"filter-form\">\n        <el-form-item label=\"搜索\">\n          <el-input v-model=\"filterForm.search\" placeholder=\"搜索用户名\" clearable @clear=\"handleSearch\"\n            @keyup.enter=\"handleSearch\" style=\"width: 200px\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"状态\">\n          <el-select v-model=\"filterForm.status\" placeholder=\"选择状态\" clearable>\n            <el-option label=\"全部\" value=\"\"></el-option>\n            <el-option label=\"已绑定\" value=\"coupled\"></el-option>\n            <el-option label=\"未绑定\" value=\"single\"></el-option>\n          </el-select>\n        </el-form-item>\n        <el-form-item>\n          <el-button type=\"primary\" @click=\"handleSearch\">搜索</el-button>\n          <el-button @click=\"resetFilter\">重置</el-button>\n        </el-form-item>\n      </el-form>\n    </el-card>\n\n    <el-card class=\"list-card\">\n      <div slot=\"header\" class=\"card-header\">\n        <span>绑定情侣关系的用户列表</span>\n        <div class=\"header-info\">\n          <el-tag size=\"small\">总计: {{ total }} 对情侣</el-tag>\n        </div>\n      </div>\n\n      <el-table :data=\"couples\" v-loading=\"loading\" border style=\"width: 100%\">\n        <el-table-column prop=\"id\" label=\"ID\" width=\"80\" align=\"center\"></el-table-column>\n        <el-table-column label=\"情侣信息\" min-width=\"300\">\n          <template slot-scope=\"scope\">\n            <div class=\"couple-info\">\n              <div class=\"user-pair\">\n                <span class=\"user-name\">{{ scope.row.user1_name }}</span>\n                <span class=\"couple-symbol\">💖</span>\n                <span class=\"user-name\">{{ scope.row.user2_name }}</span>\n              </div>\n              <div class=\"user-ids\">\n                <span>用户ID: {{ scope.row.user1_id }}</span>\n                <span>和</span>\n                <span>用户ID: {{ scope.row.user2_id }}</span>\n              </div>\n            </div>\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"relationship_start_date\" label=\"相恋日期\" width=\"120\" align=\"center\"></el-table-column>\n        <el-table-column prop=\"couple_name\" label=\"情侣名\" width=\"150\"></el-table-column>\n        <el-table-column label=\"状态\" width=\"100\" align=\"center\">\n          <template slot-scope=\"scope\">\n            <el-tag type=\"success\" size=\"small\">已绑定</el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column label=\"操作\" width=\"150\" align=\"center\">\n          <template slot-scope=\"scope\">\n            <el-button type=\"text\" size=\"mini\" @click=\"viewCouple(scope.row)\">查看详情</el-button>\n            <el-button type=\"text\" size=\"mini\" @click=\"editCouple(scope.row)\">编辑</el-button>\n            <el-button type=\"text\" size=\"mini\" @click=\"deleteCouple(scope.row)\" style=\"color: #F56C6C\">解除关系</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n\n      <div class=\"pagination-container\">\n        <el-pagination @size-change=\"handleSizeChange\" @current-change=\"handleCurrentChange\" :current-page=\"currentPage\" :page-sizes=\"[10, 20, 50, 100]\" :page-size=\"pageSize\" layout=\"total, sizes, prev, pager, next, jumper\" :total=\"total\"></el-pagination>\n      </div>\n    </el-card>\n\n    <!-- 查看/编辑对话框 -->\n    <el-dialog title=\"{{ dialogTitle }}\" :visible.sync=\"dialogVisible\" width=\"600px\">\n      <el-form :model=\"form\" label-width=\"120px\">\n        <el-form-item label=\"用户1 ID\" required>\n          <el-input v-model=\"form.user1_id\" type=\"number\" placeholder=\"请输入用户1 ID\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"用户2 ID\" required>\n          <el-input v-model=\"form.user2_id\" type=\"number\" placeholder=\"请输入用户2 ID\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"情侣名\">\n          <el-input v-model=\"form.couple_name\" placeholder=\"请输入情侣名\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"相恋日期\">\n          <el-date-picker v-model=\"form.relationship_start_date\" type=\"date\" placeholder=\"选择日期\" style=\"width: 100%\"></el-date-picker>\n        </el-form-item>\n        <el-form-item label=\"爱情誓言\">\n          <el-input type=\"textarea\" v-model=\"form.love_vow\" placeholder=\"请输入爱情誓言\" :rows=\"3\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"爱情故事\">\n          <el-input type=\"textarea\" v-model=\"form.love_story\" placeholder=\"请输入爱情故事\" :rows=\"3\"></el-input>\n        </el-form-item>\n      </el-form>\n      <div slot=\"footer\" class=\"dialog-footer\">\n        <el-button @click=\"dialogVisible = false\">取消</el-button>\n        <el-button type=\"primary\" @click=\"saveCouple\">保存</el-button>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'RecommendedCouples',\n  data() {\n    return {\n      loading: false,\n      couples: [],\n      total: 0,\n      currentPage: 1,\n      pageSize: 10,\n      filterForm: {\n        search: '',\n        status: ''\n      },\n      dialogVisible: false,\n      dialogTitle: '',\n      form: {\n        id: '',\n        user1_id: '',\n        user2_id: '',\n        user1_name: '',\n        user2_name: '',\n        couple_name: '',\n        relationship_start_date: '',\n        love_vow: '',\n        love_story: ''\n      }\n    }\n  },\n  created() {\n    this.loadData()\n  },\n  methods: {\n    async loadData() {\n      this.loading = true\n      try {\n        // 这里应该调用API获取数据\n        // const response = await getCouples({ page: this.currentPage, page_size: this.pageSize, search: this.filterForm.search, status: this.filterForm.status })\n        // 模拟数据\n        this.couples = [\n          {\n            id: 1,\n            user1_id: 1,\n            user2_id: 2,\n            user1_name: '张三',\n            user2_name: '李四',\n            couple_name: '甜蜜情侣',\n            relationship_start_date: '2025-02-14',\n            love_vow: '执子之手，与子偕老',\n            love_story: '我们在大学相遇，相知相恋'\n          },\n          {\n            id: 2,\n            user1_id: 3,\n            user2_id: 4,\n            user1_name: '王五',\n            user2_name: '赵六',\n            couple_name: '幸福恋人',\n            relationship_start_date: '2025-03-01',\n            love_vow: '爱你到永远',\n            love_story: '我们在工作中相识，彼此吸引'\n          }\n        ]\n        this.total = this.couples.length\n      } catch (error) {\n        this.$message.error('加载失败')\n      } finally {\n        this.loading = false\n      }\n    },\n    handleSearch() {\n      this.currentPage = 1\n      this.loadData()\n    },\n    resetFilter() {\n      this.filterForm = {\n        search: '',\n        status: ''\n      }\n      this.currentPage = 1\n      this.loadData()\n    },\n    handleSizeChange(val) {\n      this.pageSize = val\n      this.loadData()\n    },\n    handleCurrentChange(val) {\n      this.currentPage = val\n      this.loadData()\n    },\n    refreshData() {\n      this.loadData()\n      this.$message.success('数据已刷新')\n    },\n    viewCouple(couple) {\n      this.dialogTitle = '查看情侣详情'\n      this.form = { ...couple }\n      this.dialogVisible = true\n    },\n    editCouple(couple) {\n      this.dialogTitle = '编辑情侣信息'\n      this.form = { ...couple }\n      this.dialogVisible = true\n    },\n    async saveCouple() {\n      try {\n        // 这里应该调用API保存数据\n        this.$message.success('保存成功')\n        this.dialogVisible = false\n        this.loadData()\n      } catch (error) {\n        this.$message.error('保存失败')\n      }\n    },\n    async deleteCouple(couple) {\n      this.$confirm('确定要解除这对情侣的关系吗？', '确认解除', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(async () => {\n        try {\n          // 这里应该调用API删除数据\n          this.$message.success('解除关系成功')\n          this.loadData()\n        } catch (error) {\n          this.$message.error('解除关系失败')\n        }\n      }).catch(() => {})\n    }\n  }\n}\n</script>\n\n<style scoped>\n.recommended-couples {\n  padding: 20px;\n}\n\n.page-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 20px;\n}\n\n.page-header h1 {\n  margin: 0;\n  color: #303133;\n}\n\n.filter-card {\n  margin-bottom: 20px;\n}\n\n.list-card {\n  margin-bottom: 20px;\n}\n\n.card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.header-info {\n  display: flex;\n  gap: 10px;\n}\n\n.couple-info {\n  line-height: 1.5;\n}\n\n.user-pair {\n  font-weight: bold;\n  color: #303133;\n}\n\n.couple-symbol {\n  margin: 0 8px;\n  font-size: 16px;\n}\n\n.user-ids {\n  font-size: 12px;\n  color: #909399;\n}\n\n.pagination-container {\n  margin-top: 20px;\n  text-align: right;\n}\n</style>"],"mappings":"AA2GA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,OAAA;MACAC,OAAA;MACAC,KAAA;MACAC,WAAA;MACAC,QAAA;MACAC,UAAA;QACAC,MAAA;QACAC,MAAA;MACA;MACAC,aAAA;MACAC,WAAA;MACAC,IAAA;QACAC,EAAA;QACAC,QAAA;QACAC,QAAA;QACAC,UAAA;QACAC,UAAA;QACAC,WAAA;QACAC,uBAAA;QACAC,QAAA;QACAC,UAAA;MACA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,QAAA;EACA;EACAC,OAAA;IACA,MAAAD,SAAA;MACA,KAAArB,OAAA;MACA;QACA;QACA;QACA;QACA,KAAAC,OAAA,IACA;UACAU,EAAA;UACAC,QAAA;UACAC,QAAA;UACAC,UAAA;UACAC,UAAA;UACAC,WAAA;UACAC,uBAAA;UACAC,QAAA;UACAC,UAAA;QACA,GACA;UACAR,EAAA;UACAC,QAAA;UACAC,QAAA;UACAC,UAAA;UACAC,UAAA;UACAC,WAAA;UACAC,uBAAA;UACAC,QAAA;UACAC,UAAA;QACA,EACA;QACA,KAAAjB,KAAA,QAAAD,OAAA,CAAAsB,MAAA;MACA,SAAAC,KAAA;QACA,KAAAC,QAAA,CAAAD,KAAA;MACA;QACA,KAAAxB,OAAA;MACA;IACA;IACA0B,aAAA;MACA,KAAAvB,WAAA;MACA,KAAAkB,QAAA;IACA;IACAM,YAAA;MACA,KAAAtB,UAAA;QACAC,MAAA;QACAC,MAAA;MACA;MACA,KAAAJ,WAAA;MACA,KAAAkB,QAAA;IACA;IACAO,iBAAAC,GAAA;MACA,KAAAzB,QAAA,GAAAyB,GAAA;MACA,KAAAR,QAAA;IACA;IACAS,oBAAAD,GAAA;MACA,